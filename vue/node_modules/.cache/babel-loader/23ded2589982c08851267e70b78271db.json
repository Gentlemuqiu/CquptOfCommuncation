      <el-switch\r\n            @change=\"change(scope.row, 'forbidComment')\"\r\n            v-model=\"scope.row.forbidComment\"\r\n            active-color=\"#f00\"\r\n            inactive-color=\"#ddd\"\r\n          >\r\n          </el-switch>\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column label=\"禁止登录\">\r\n        <template #default=\"scope\">\r\n          <el-switch\r\n            @change=\"change(scope.row, 'forbidLogin')\"\r\n            v-model=\"scope.row.forbidLogin\"\r\n            active-color=\"#f00\"\r\n            inactive-color=\"#ddd\"\r\n          >\r\n          </el-switch>\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column label=\"操作\">\r\n        <template #default=\"scope\">\r\n          <el-popconfirm\r\n            title=\"确定删除吗？\"\r\n            @confirm=\"handleDelete(scope.row.id)\"\r\n          >\r\n            <template #reference>\r\n              <el-button size=\"mini\" type=\"danger\">删除</el-button>\r\n            </template>\r\n          </el-popconfirm>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n\r\n    <!-- 分页 -->\r\n    <div style=\"margin: 10px 0\">\r\n      <el-pagination\r\n        @size-change=\"handleSizeChange\"\r\n        @current-change=\"handleCurrentChange\"\r\n        :current-page=\"pageNum\"\r\n        :page-sizes=\"[5, 10, 20]\"\r\n        :page-size=\"pageSize\"\r\n        layout=\"total, sizes, prev, pager, next, jumper\"\r\n        :total=\"total\"\r\n      >\r\n      </el-pagination>\r\n    </div>\r\n\r\n    <!-- 弹窗表单 -->\r\n    <el-dialog title=\"信息\" v-model=\"dialogVisible\" width=\"40%\">\r\n      <el-form :model=\"entity\" label-width=\"120px\">\r\n        <el-form-item label=\"用户名\">\r\n          <el-input v-model=\"entity.username\" style=\"width: 80%\" clearable></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"昵称\">\r\n          <el-input v-model=\"entity.nickName\" style=\"width: 80%\" clearable></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"手机号\">\r\n          <el-input v-model=\"entity.phone\" type=\"number\" style=\"width: 80%\" clearable></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"年龄\">\r\n          <el-input v-model=\"entity.age\" type=\"number\" style=\"width: 80%\" clearable></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"性别\">\r\n          <el-radio v-model=\"entity.sex\" label=\"男\">男</el-radio>\r\n          <el-radio v-model=\"entity.sex\" label=\"女\">女</el-radio>\r\n          <el-radio v-model=\"entity.sex\" label=\"未知\">未知</el-radio>\r\n        </el-form-item>\r\n        <el-form-item label=\"地址\">\r\n          <el-input\r\n            type=\"textarea\"\r\n            v-model=\"entity.address\"\r\n            style=\"width: 80%\"\r\n            clearable\r\n          ></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <template #footer>\r\n        <span class=\"dialog-footer\">\r\n          <el-button @click=\"dialogVisible = false\">取消</el-button>\r\n          <el-button type=\"primary\" @click=\"save\">确定</el-button>\r\n        </span>\r\n      </template>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from \"@/utils/request\";\r\n\r\nconst url = \"/user\";\r\n\r\nexport default {\r\n  name: \"User\",\r\n  data() {\r\n    return {\r\n      loading: false,\r\n      entity: {},\r\n      dialogVisible: false,\r\n      search: \"\",\r\n      pageNum: 1,\r\n      pageSize: 10,\r\n      total: 0,\r\n      tableData: [],\r\n    };\r\n  },\r\n  created() {\r\n    this.load();\r\n  },\r\n  methods: {\r\n    showMessage(type, message) {\r\n      this.$message({ type, message });\r\n    },\r\n    load() {\r\n      this.loading = true;\r\n      request\r\n        .get(`${url}/page`, {\r\n          params: {\r\n            pageNum: this.pageNum,\r\n            pageSize: this.pageSize,\r\n            search: this.search,\r\n          },\r\n        })\r\n        .then((res) => {\r\n          this.loading = false;\r\n          // 过滤掉管理员\r\n          this.tableData = res.data.records.filter(item => item.role !== 1); \r\n          this.total = this.tableData.length; // 更新总条数\r\n        })\r\n        .catch(() => {\r\n          this.loading = false;\r\n          this.showMessage(\"error\", \"加载失败，请稍后重试\");\r\n        });\r\n    },\r\n    save() {\r\n      const method = this.entity.id ? \"put\" : \"post\";\r\n      request[method](url, this.entity)\r\n        .then((res) => {\r\n          if (res.code === \"0\") {\r\n            this.showMessage(\"success\", this.entity.id ? \"更新成功\" : \"新增成功\");\r\n            this.load();\r\n            this.dialogVisible = false;\r\n          } else {\r\n            this.showMessage(\"error\", res.msg);\r\n          }\r\n        })\r\n        .catch(() => {\r\n          this.showMessage(\"error\", \"操作失败，请稍后重试\");\r\n        });\r\n    },\r\n    handleDelete(id) {\r\n      request\r\n        .delete(`${url}/${id}`)\r\n        .then((res) => {\r\n          if (res.code === \"0\") {\r\n            this.showMessage(\"success\", \"删除成功\");\r\n            this.load();\r\n          } else {\r\n            this.showMessage(\"error\", res.msg);\r\n          }\r\n        })\r\n        .catch(() => {\r\n          this.showMessage(\"error\", \"删除失败，请稍后重试\");\r\n        });\r\n    },\r\n    change(row, field) {\r\n      request\r\n        .put(url, row)\r\n        .then((res) => {\r\n          if (res.code === \"0\") {\r\n            this.showMessage(\"success\", `${field === \"forbidComment\" ? \"评论权限\" : \"登录权限\"}修改成功`);\r\n          } else {\r\n            this.showMessage(\"error\", res.msg);\r\n          }\r\n        })\r\n        .catch(() => {\r\n          this.showMessage(\"error\", \"权限修改失败，请稍后重试\");\r\n        });\r\n    },\r\n    handleSizeChange(pageSize) {\r\n      this.pageSize = pageSize;\r\n      this.load();\r\n    },\r\n    handleCurrentChange(pageNum) {\r\n      this.pageNum = pageNum;\r\n      this.load();\r\n    },\r\n  },\r\n};\r\n</script>\r\n"],"mappings":";;EACOA,KAAqB,EAArB;IAAA;EAAA;AAAqB;;EAGnBA,KAAsB,EAAtB;IAAA;EAAA;AAAsB;;EAkEtBA,KAAsB,EAAtB;IAAA;EAAA;AAAsB;;EA2CjBC,KAAK,EAAC;AAAe;;;;;;;;;;;;;;uBAhHjCC,mBAAA,CAsHM,OAtHNC,UAsHM,GAnHJC,mBAAA,CAYM,OAZNC,UAYM,GAXJC,YAAA,CAKYC,mBAAA;gBAJDC,KAAA,CAAAC,MAAM;+DAAND,KAAA,CAAAC,MAAM,GAAAC,MAAA;IACfC,WAAW,EAAC,QAAQ;IACpBX,KAAkB,EAAlB;MAAA;IAAA,CAAkB;IAClBY,SAAS,EAAT;+BAEFN,YAAA,CAIeO,oBAAA;IAHbC,IAAI,EAAC,SAAS;IACdd,KAAwB,EAAxB;MAAA;IAAA,CAAwB;IACvBe,OAAK,EAAEC,QAAA,CAAAC;;sBACT,MAAEC,MAAA,SAAAA,MAAA,Q,iBAAF,IAAE,E;;uDAILC,YAAA,CAgDWC,mBAAA;IA9CRC,IAAI,EAAEb,KAAA,CAAAc,SAAS;IAChBC,MAAM,EAAN,EAAM;IACNC,MAAM,EAAN,EAAM;IACNxB,KAAkF,EAAlF;MAAA;MAAA;MAAA;IAAA;;sBAEA,MAAiE,CAAjEM,YAAA,CAAiEmB,0BAAA;MAAhDC,IAAI,EAAC,IAAI;MAACC,KAAK,EAAC,IAAI;MAACC,QAAQ,EAAR;QACtCtB,YAAA,CAA+DmB,0BAAA;MAA9CC,IAAI,EAAC,UAAU;MAACC,KAAK,EAAC;QACvCrB,YAAA,CAA8DmB,0BAAA;MAA7CC,IAAI,EAAC,UAAU;MAACC,KAAK,EAAC;QACvCrB,YAAA,CAA4DmB,0BAAA;MAA3CC,IAAI,EAAC,OAAO;MAACC,KAAK,EAAC;QACpCrB,YAAA,CAAyDmB,0BAAA;MAAxCC,IAAI,EAAC,KAAK;MAACC,KAAK,EAAC;QAClCrB,YAAA,CAAyDmB,0BAAA;MAAxCC,IAAI,EAAC,KAAK;MAACC,KAAK,EAAC;QAClCrB,YAAA,CAA6DmB,0BAAA;MAA5CC,IAAI,EAAC,SAAS;MAACC,KAAK,EAAC;QACtCrB,YAAA,CAUkBmB,0BAAA;MAVDE,KAAK,EAAC;IAAM;MAChBE,OAAO,EAAAC,QAAA,CAAEC,KAAK,KACvBzB,YAAA,CAMY0B,oBAAA;QALTC,QAAM,EAAAvB,MAAA,IAAEM,QAAA,CAAAkB,MAAM,CAACH,KAAK,CAACI,GAAG;oBAChBJ,KAAK,CAACI,GAAG,CAACC,aAAa;yCAAvBL,KAAK,CAACI,GAAG,CAACC,aAAa,GAAA1B,MAAA;QAChC,cAAY,EAAC,MAAM;QACnB,gBAAc,EAAC;;;QAKrBJ,YAAA,CAUkBmB,0BAAA;MAVDE,KAAK,EAAC;IAAM;MAChBE,OAAO,EAAAC,QAAA,CAAEC,KAAK,KACvBzB,YAAA,CAMY0B,oBAAA;QALTC,QAAM,EAAAvB,MAAA,IAAEM,QAAA,CAAAkB,MAAM,CAACH,KAAK,CAACI,GAAG;oBAChBJ,KAAK,CAACI,GAAG,CAACE,WAAW;yCAArBN,KAAK,CAACI,GAAG,CAACE,WAAW,GAAA3B,MAAA;QAC9B,cAAY,EAAC,MAAM;QACnB,gBAAc,EAAC;;;QAKrBJ,YAAA,CAWkBmB,0BAAA;MAXDE,KAAK,EAAC;IAAI;MACdE,OAAO,EAAAC,QAAA,CAAEC,KAAK,KACvBzB,YAAA,CAOgBgC,wBAAA;QANdC,KAAK,EAAC,QAAQ;QACbC,SAAO,EAAA9B,MAAA