user.id).then(res => {\r\n        if (res.code === '0') {\r\n          this.user = res.data\r\n        }\r\n      })\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.admin-aside {\r\n  width: 220px;\r\n  flex-shrink: 0;\r\n  background: var(--bg-primary);\r\n  border: 1px solid var(--border-light);\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: var(--shadow-base);\r\n  overflow: hidden;\r\n}\r\n\r\n.aside-title {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--spacing-sm);\r\n  padding: var(--spacing-md) var(--spacing-lg);\r\n  color: var(--text-primary);\r\n  font-weight: var(--font-weight-semibold);\r\n  border-bottom: 1px solid var(--border-light);\r\n  background: linear-gradient(135deg, #ecfeff 0%, #f8fafc 100%);\r\n}\r\n\r\n.aside-menu {\r\n  border-right: none;\r\n}\r\n\r\n.aside-menu :deep(.el-menu-item),\r\n.aside-menu :deep(.el-submenu__title) {\r\n  height: 44px;\r\n  line-height: 44px;\r\n}\r\n\r\n.aside-menu :deep(.el-menu-item i),\r\n.aside-menu :deep(.el-submenu__title i) {\r\n  margin-right: var(--spacing-sm);\r\n}\r\n\r\n.aside-menu :deep(.el-menu-item.is-active) {\r\n  background: #ecfeff;\r\n  color: var(--primary-color);\r\n  border-right: 2px solid var(--primary-color);\r\n}\r\n\r\n@media (max-width: 900px) {\r\n  .admin-aside {\r\n    width: 100%;\r\n  }\r\n}\r\n</style>\r\n"],"mappings":";;EACSA,KAAK,EAAC;AAAa;;;;;uBAA1BC,mBAAA,CAsBQ,SAtBRC,UAsBQ,G,0BArBNC,mBAAA,CAGM;IAHDH,KAAK,EAAC;EAAa,IACtBG,mBAAA,CAA8B;IAA3BH,KAAK,EAAC;EAAgB,IACzBG,mBAAA,CAAiB,cAAX,MAAI,E,QAGZC,YAAA,CAeUC,kBAAA;IAfA,gBAAc,EAAEC,KAAA,CAAAC,IAAI;IAAEC,MAAM,EAAN,EAAM;IAACR,KAAK,EAAC;;sBAC3C,MAQa,CARoBS,QAAA,CAAAC,WAAW,CAACC,MAAM,I,cAAnDC,YAAA,CAQaC,qBAAA;;MARDC,KAAK,EAAC;;MACLC,KAAK,EAAAC,QAAA,CACd,MAAiBC,MAAA,QAAAA,MAAA,OAAjBd,mBAAA,CAAiB,cAAX,MAAI,M;wBAEE,MAA2B,E,kBAAzCF,mBAAA,CAGeiB,SAAA,QAAAC,WAAA,CAHcV,QAAA,CAAAC,WAAW,EAAnBU,IAAI;6BAAzBR,YAAA,CAGeS,uBAAA;UAH4BC,GAAG,EAAEF,IAAI,CAACb,IAAI;UAAGO,KAAK,EAAEM,IAAI,CAACb;;4BACtE,MAA0B,CAA1BJ,mB