/front/collectedContent',\r\n      label: '我的收藏',\r\n      icon: 'el-icon-star-off'\r\n    });\r\n  }\r\n\r\n  return items;\r\n}\r\n\r\n/** 用户下拉菜单 */\r\nexport function getUserDropdownItems(user = {}) {\r\n  const items = [];\r\n\r\n  if (user.role === 1) {\r\n    items.push({\r\n      path: '/sayings',\r\n      label: '后台管理',\r\n      icon: 'el-icon-setting'\r\n    });\r\n  }\r\n\r\n  if (user.role === 2) {\r\n    items.push({\r\n      path: '/front/littleSaying',\r\n      label: '发布信息',\r\n      icon: 'el-icon-edit'\r\n    });\r\n  }\r\n\r\n  return items.concat([\r\n    { path: '/front/person',           label: '个人信息',     icon: 'el-icon-user' },\r\n    { path: '/front/collectedContent', label: '我的收藏',     icon: 'el-icon-collection' },\r\n    { path: '/front/subscribePerson',  label: '我关注的人',   icon: 'el-icon-coordinate' },\r\n  ]);\r\n}\r\n\r\n/** 后台管理侧边栏 */\r\nexport const ADMIN_SIDEBAR_ITEMS = [\r\n  { path: '/user',    label: '用户管理', icon: 'el-icon-user-solid',      requireRole: 1, group: '系统管理' },\r\n  { path: '/sayings', label: '信息管理', icon: 'el-icon-s-order' },\r\n  { path: '/jubao',   label: '投诉管理', icon: 'el-icon-warning-outline' },\r\n  { path: '/comment', label: '评论管理', icon: 'el-icon-chat-dot-round' },\r\n  { path: '/notice',  label: '公告管理', icon: 'el-icon-bell' },\r\n];\r\n"],"mappings":";AAAA;;AAEA;AACA,OAAO,MAAMA,UAAU,GAAG,CACxB;EAAEC,GAAG,EAAE,MAAM;EAAEC,KAAK,EAAE,MAAM;EAAEC,IAAI,EAAE;AAAK,CAAC,EAC1C;EAAEF,GAAG,EAAE,MAAM;EAAEC,KAAK,EAAE,MAAM;EAAEC,IAAI,EAAE;AAAK,CAAC,EAC1C;EAAEF,GAAG,EAAE,MAAM;EAAEC,KAAK,EAAE,MAAM;EAAEC,IAAI,EAAE;AAAK,CAAC,EAC1C;EAAEF,GAAG,EAAE,MAAM;EAAEC,KAAK,EAAE,MAAM;EAAEC,IAAI,EAAE;AAAK,CAAC,EAC1C;EAAEF,GAAG,EAAE,MAAM;EAAEC,KAAK,EAAE,MAAM;EAAEC,IAAI,EAAE;AAAK,CAAC,CAC3C;;AAED;AACA,OAAO,SAASC,iBAAiBA,CAACC,IAAI,GAAG,CAAC,CAAC,EAAE;EAC3C,MAAMC,KAAK,GAAG,CACZ;IAAEC,IAAI,EAAE,aAAa;IAAEL,KAAK,EAAE,IAAI;IAAEC,IAAI,EAAE;EAAgB,CAAC,CAC5D;EAED,IAAIE,IAAI,CAACG,EAAE,IAAIH,IAAI,CAACI,IAAI,KAAK,CAAC,EAAE;IAC9BH,KAAK,CAACI,IAAI,CAAC;MACTH