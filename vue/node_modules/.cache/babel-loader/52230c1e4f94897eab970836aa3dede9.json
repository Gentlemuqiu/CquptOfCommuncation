       confirm-button-text=\"确认处理\"\r\n              cancel-button-text=\"取消\"\r\n              @confirm=\"handleDelete(scope.row)\"\r\n            >\r\n              <template #reference>\r\n                <el-button size=\"small\" type=\"danger\">\r\n                  <el-icon><Check /></el-icon>处理并删除\r\n                </el-button>\r\n              </template>\r\n            </el-popconfirm>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n    </div>\r\n\r\n    <el-empty v-if=\"!loading && tableData.length === 0\" description=\"暂无投诉记录\" />\r\n\r\n    <div class=\"admin-pagination\">\r\n      <el-pagination\r\n        @size-change=\"handleSizeChange\"\r\n        @current-change=\"handleCurrentChange\"\r\n        :current-page=\"pageNum\"\r\n        :page-sizes=\"[10, 20, 50]\"\r\n        :page-size=\"pageSize\"\r\n        layout=\"total, sizes, prev, pager, next\"\r\n        :total=\"total\"\r\n      />\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { getJubaoPage, deleteJubao } from '@/api/jubao'\r\nimport { deleteMessage } from '@/api/message'\r\nimport { Warning, InfoFilled, Check } from '@element-plus/icons-vue'\r\n\r\nexport default {\r\n  name: 'Jubao',\r\n  components: { Warning, InfoFilled, Check },\r\n  data() {\r\n    return {\r\n      loading: false,\r\n      pageNum: 1,\r\n      pageSize: 10,\r\n      total: 0,\r\n      tableData: [],\r\n    }\r\n  },\r\n  created() {\r\n    this.load()\r\n  },\r\n  methods: {\r\n    load() {\r\n      this.loading = true\r\n      getJubaoPage({ pageNum: this.pageNum, pageSize: this.pageSize })\r\n        .then(res => {\r\n          if (res.code === '0') {\r\n            this.tableData = res.data.records || []\r\n            this.total = res.data.total || 0\r\n          }\r\n        })\r\n        .catch(() => {})\r\n        .finally(() => { this.loading = false })\r\n    },\r\n    async handleDelete(row) {\r\n      this.loading = true\r\n      try {\r\n        await deleteMessage(row.commentId)\r\n        await deleteJubao(row.id)\r\n        this.$message.success('投诉已处理，评论已删除')\r\n        this.load()\r\n      } catch {\r\n        this.$message.error('操作失败，请稍后重试')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n    handleSizeChange(ps) {\r\n      this.pageSize = ps\r\n      this.load()\r\n    },\r\n    handleCurrentChange(pn) {\r\n      this.pageNum = pn\r\n      this.load()\r\n    },\r\n  },\r\n}\r\n</script>\r\n\r\n<style scoped></style>\r\n"],"mappings":";;EACOA,KAAK,EAAC;AAAY;;EAEhBA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAAkB;;EACtBA,KAAK,EAAC;AAAsB;;;EAQ7BA,KAAK,EAAC;;;EAKTA,KAAK,EAAC;AAAe;;EAClBA,KAAK,EAAC;AAAa;;EAMtBA,KAAK,EAAC;AAAkB;;EA0BxBA,KAAK,EAAC;AAAkB;;;;;;;;;;;;;uBAlD/BC,mBAAA,CA6DM,OA7DNC,UA6DM,GA3DJC,mBAAA,CAaM,OAbNC,UAaM,GAZJD,mBAAA,CAQM,OARNE,UAQM,GAPJF,mBAAA,CAEM,OAFNG,UAEM,GADJC,YAAA,CAA8BC,kBAAA;sBAArB,MAAW,CAAXD,YAAA,CAAWE,kBAAA,E;;kCAEtBN,mBAAA,CAGM,cAFJA,mBAAA,CAAuC;IAAnCH,KAAK,EAAC;EAAmB,GAAC,MAAI,GAClCG,mBAAA,CAAiD;IAA9CH,KAAK,EAAC;EAAkB,GAAC,mBAAiB,E,UAGXU,KAAA,CAAAC,KAAK,Q,cAA3CV,mBAAA,CAEO,QAFPW,UAEO,EAF0C,OAC3C,GAAAC,gBAAA,CAAGH,KAAA,CAAAC,KAAK,IAAG,KACjB,Q,iCAGFR,mBAAA,CAKM,OALNW,UAKM,GAJJX,mBAAA,CAGO,QAHPY,UAGO,GAFLR,YAAA,CAAkEC,kBAAA;IAAzDQ,KAAgC,EAAhC;MAAA;IAAA;EAAgC;sBAAC,MAAc,CAAdT,YAAA,CAAcU,qBAAA,E;;iDAAU,mBAEpE,G,KAGFd,mBAAA,CAsBM,OAtBNe,UAsBM,G,+BArBJC,YAAA,CAoBWC,mBAAA;IApBoBC,IAAI,EAAEX,KAAA,CAAAY,SAAS;IAAEC,MAAM,EAAN,EAAM;IAACC,MAAM,EAAN,EAAM;IAACR,KAAmB,EAAnB;MAAA;IAAA;;sBAC5D,MAAkE,CAAlET,YAAA,CAAkEkB,0BAAA;MAAjDC,IAAI,EAAC,MAAM;MAAUC,KAAK,EAAC,KAAK;MAAGC,KAAK,EAAC;QAC1DrB,YAAA,CAAiEkB,0BAAA;MAAhDC,IAAI,EAAC,aAAa;MAAGC,KAAK,EAAC,MAAM;MAACC,KAAK,EAAC;QACzDrB,YAAA,CAA2FkB,0BAAA;MAA1EC,IAAI,EAAC,SAAS;MAAOC,KAAK,EAAC,MAAM;MAAC,WAAS,EAAC,KAAK;MAAC,uBAAqB,EAArB;QACnEpB,YAAA,CAekBkB,0BAAA;MAfDE,KAAK,EAAC,IAAI;MAACC,KAAK,EAAC,KAAK;MAACC,KAAK,EAAC,QAAQ;MAACC,KAAK,EAAC;;MAChDC,OAAO,EAAAC,QAAA,CAAEC,KAAK,KACvB1B,YAAA,CAWgB2B,wBAAA;QAVdC,KAAK,EAAC,iBAAiB;QACvB,qBAAmB,EAAC,