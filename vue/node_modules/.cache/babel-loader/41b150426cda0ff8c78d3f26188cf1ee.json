n  transform: scale(1.1);\r\n}\r\n\r\n/* 激活状态 */\r\n.aside-menu :deep(.el-menu-item.is-active) {\r\n  background: var(--primary-gradient-soft) !important;\r\n  color: var(--primary-color) !important;\r\n  font-weight: var(--font-weight-semibold) !important;\r\n  box-shadow: inset 3px 0 0 var(--primary-color);\r\n}\r\n\r\n.aside-menu :deep(.el-menu-item.is-active i) {\r\n  color: var(--primary-color) !important;\r\n}\r\n\r\n/* 子菜单 */\r\n.aside-menu :deep(.el-sub-menu .el-menu) {\r\n  background: var(--bg-secondary) !important;\r\n  padding: var(--spacing-xs) 0;\r\n}\r\n\r\n.aside-menu :deep(.el-sub-menu .el-menu-item) {\r\n  height: 40px !important;\r\n  line-height: 40px !important;\r\n  padding-left: 48px !important;\r\n  font-size: var(--font-size-sm) !important;\r\n}\r\n\r\n/* ── 响应式 ── */\r\n@media (max-width: 900px) {\r\n  .admin-aside {\r\n    width: 100%;\r\n    position: static;\r\n  }\r\n}\r\n</style>\r\n"],"mappings":";;AA4CA,OAAOA,OAAM,MAAO,iBAAiB;AACrC,SAASC,mBAAkB,QAAS,qBAAqB;AAEzD,eAAe;EACbC,IAAI,EAAE,YAAY;EAClBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAE,CAAC,CAAC;MACRC,IAAI,EAAE,IAAI,CAACC,MAAM,CAACD;IACpB,CAAC;EACH,CAAC;EACDE,QAAQ,EAAE;IACRC,aAAaA,CAAA,EAAG;MACd,OAAOP,mBAAmB,CAACQ,MAAM,CAACC,IAAG,IAAK;QACxC,IAAI,CAACA,IAAI,CAACC,WAAW,EAAE,OAAO,IAAI;QAClC,OAAOD,IAAI,CAACC,WAAU,KAAM,IAAI,CAACP,IAAI,CAACQ,IAAI;MAC5C,CAAC,CAAC;IACJ,CAAC;IACDC,WAAWA,CAAA,EAAG;MACZ,OAAO,IAAI,CAACL,aAAa,CAACC,MAAM,CAACC,IAAG,IAAKA,IAAI,CAACI,KAAI,KAAM,MAAM,CAAC;IACjE,CAAC;IACDC,WAAWA,CAAA,EAAG;MACZ,OAAO,IAAI,CAACP,aAAa,CAACC,MAAM,CAACC,IAAG,IAAKA,IAAI,CAACI,KAAI,KAAM,MAAM,CAAC;IACjE;EACF,CAAC;EACDE,OAAOA,CAAA,EAAG;IACR,MAAMC,OAAM,GAAIC,cAAc,CAACC,OAAO,CAAC,MAAM,KAAK,IAAI;IACtD,IAAI,CAACf,IAAG,GAAIgB,IAAI,CAACC,KAAK,CAACJ,OAAO,CAAC;IAE/B,IAAI,IAAI,CAACb,IAAI,CAACkB,EAAE,EAAE;MAChBtB,OAAO,CAACuB,GAAG,CAAC,QAAO,GAAI,IAAI,CAACnB,IAAI,CAACkB,EAAE,CAAC,CAACE,IAAI,CAACC,GAAE,IAAK;QAC/C,IAAIA,GAAG,CAACC,IAAG,KAAM,GAAG,EAAE;UACpB,IAAI,CAACtB,IAAG,GAAIqB,GAAG,CAACtB,IAAI;QACtB;MACF,C