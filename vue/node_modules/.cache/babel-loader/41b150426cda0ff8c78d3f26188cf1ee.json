"el-icon-menu\"></i>\r\n        <span>功能导航</span>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 导航菜单 -->\r\n    <el-menu :default-active=\"path\" router class=\"aside-menu\" unique-opened>\r\n      <!-- 系统管理分组 -->\r\n      <el-sub-menu index=\"system\" v-if=\"systemItems.length\">\r\n        <template #title>\r\n          <i class=\"el-icon-setting\"></i>\r\n          <span>系统管理</span>\r\n        </template>\r\n        <el-menu-item\r\n          v-for=\"item in systemItems\"\r\n          :key=\"item.path\"\r\n          :index=\"item.path\"\r\n          class=\"sub-menu-item\"\r\n        >\r\n          <i :class=\"item.icon\"></i>\r\n          <span>{{ item.label }}</span>\r\n        </el-menu-item>\r\n      </el-sub-menu>\r\n\r\n      <!-- 普通菜单项 -->\r\n      <el-menu-item\r\n        v-for=\"item in normalItems\"\r\n        :key=\"item.path\"\r\n        :index=\"item.path\"\r\n        class=\"menu-item\"\r\n      >\r\n        <i :class=\"item.icon\"></i>\r\n        <span>{{ item.label }}</span>\r\n      </el-menu-item>\r\n    </el-menu>\r\n  </aside>\r\n</template>\r\n\r\n<script>\r\nimport request from \"@/utils/request\";\r\nimport { ADMIN_SIDEBAR_ITEMS } from \"@/config/navigation\";\r\n\r\nexport default {\r\n  name: \"AdminAside\",\r\n  data() {\r\n    return {\r\n      user: {},\r\n      path: this.$route.path\r\n    };\r\n  },\r\n  computed: {\r\n    filteredItems() {\r\n      return ADMIN_SIDEBAR_ITEMS.filter(item => {\r\n        if (!item.requireRole) return true;\r\n        return item.requireRole === this.user.role;\r\n      });\r\n    },\r\n    systemItems() {\r\n      return this.filteredItems.filter(item => item.group === '系统管理');\r\n    },\r\n    normalItems() {\r\n      return this.filteredItems.filter(item => item.group !== '系统管理');\r\n    }\r\n  },\r\n  created() {\r\n    const userStr = sessionStorage.getItem(\"user\") || \"{}\";\r\n    this.user = JSON.parse(userStr);\r\n\r\n    if (this.user.id) {\r\n      request.get(\"/user/\" + this.user.id).t