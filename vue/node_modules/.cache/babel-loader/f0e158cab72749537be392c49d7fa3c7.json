"     label=\"评论时间\" width=\"160\" />\n        <el-table-column label=\"操作\" width=\"90\" align=\"center\" fixed=\"right\">\n          <template #default=\"scope\">\n            <el-popconfirm title=\"确定删除该评论吗？\" @confirm=\"handleDelete(scope.row.id)\">\n              <template #reference>\n                <el-button size=\"small\" type=\"danger\">删除</el-button>\n              </template>\n            </el-popconfirm>\n          </template>\n        </el-table-column>\n      </el-table>\n    </div>\n\n    <el-empty v-if=\"!loading && tableData.length === 0\" description=\"暂无评论\" />\n\n    <div class=\"admin-pagination\">\n      <el-pagination\n        @size-change=\"handleSizeChange\"\n        @current-change=\"handleCurrentChange\"\n        :current-page=\"pageNum\"\n        :page-sizes=\"[10, 20, 50]\"\n        :page-size=\"pageSize\"\n        layout=\"total, sizes, prev, pager, next\"\n        :total=\"total\"\n      />\n    </div>\n  </div>\n</template>\n\n<script>\nimport { getMessagePage, deleteMessage } from '@/api/message'\nimport { ChatDotRound, Search } from '@element-plus/icons-vue'\n\nexport default {\n  name: 'Comment',\n  components: { ChatDotRound, Search },\n  data() {\n    return {\n      loading: false,\n      search: '',\n      pageNum: 1,\n      pageSize: 10,\n      total: 0,\n      tableData: []\n    }\n  },\n  created() {\n    this.load()\n  },\n  methods: {\n    load() {\n      this.loading = true\n      getMessagePage({\n        pageNum: this.pageNum,\n        pageSize: this.pageSize,\n        search: this.search\n      })\n        .then(res => {\n          this.tableData = res.data.records || []\n          this.total = res.data.total || 0\n        })\n        .catch(() => {})\n        .finally(() => { this.loading = false })\n    },\n    handleDelete(id) {\n      deleteMessage(id).then(res => {\n        if (res.code === '0') {\n          this.$message.success('删除成功')\n          this.load()\n        } else {\n          this.$message.error(res.msg)\n        }\n      })\n    },\n    handleSizeChange(ps) {\n      this.pageSize = ps\n      this.load()\n    },\n    handleCurrentChange(pn) {\n      this.pageNum = pn\n      this.load()\n    },\n  }\n}\n</script>\n\n<style scoped>\n.text-clamp {\n  display: -webkit-box;\n  -webkit-line-clamp: 2;\n  -webkit-box-orient: vertical;\n  overflow: hidden;\n  font-size: var(--font-size-sm);\n  color: var(--text-secondary);\n  line-height: var(--line-height-snug);\n}\n</style>\n"],"mappings":";;EACOA,KAAK,EAAC;AAAY;;EAEhBA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAAkB;;EACtBA,KAAK,EAAC;AAAuB;;;EAQ9BA,KAAK,EAAC;;;EAKTA,KAAK,EAAC;AAAe;;EAcrBA,KAAK,EAAC;AAAkB;;EAKfA,KAAK,EAAC;AAAY;;EAmB3BA,KAAK,EAAC;AAAkB;;;;;;;;;;;;;uBAvD/BC,mBAAA,CAkEM,OAlENC,UAkEM,GAjEJC,mBAAA,UAAa,EACbC,mBAAA,CAaM,OAbNC,UAaM,GAZJD,mBAAA,CAQM,OARNE,UAQM,GAPJF,mBAAA,CAEM,OAFNG,UAEM,GADJC,YAAA,CAAmCC,kBAAA;sBAA1B,MAAgB,CAAhBD,YAAA,CAAgBE,uBAAA,E;;kCAE3BN,mBAAA,CAGM,cAFJA,mBAAA,CAAuC;IAAnCJ,KAAK,EAAC;EAAmB,GAAC,MAAI,GAClCI,mBAAA,CAA2C;IAAxCJ,KAAK,EAAC;EAAkB,GAAC,aAAW,E,wBAGLW,KAAA,CAAAC,KAAK,Q,cAA3CX,mBAAA,CAEO,QAFPY,UAEO,EAF0C,KAC7C,GAAAC,gBAAA,CAAGH,KAAA,CAAAC,KAAK,IAAG,OACf,mB,qCAGFR,mBAAA,CAYM,OAZNW,UAYM,GAXJP,YAAA,CAUWQ,mBAAA;gBATAL,KAAA,CAAAM,MAAM;+DAANN,KAAA,CAAAM,MAAM,GAAAC,MAAA;IACfC,WAAW,EAAC,iBAAiB;IAC7BC,SAAS,EAAT,EAAS;IACTpB,KAAK,EAAC,cAAc;IACnBqB,OAAK,EAAAC,SAAA,CAAQC,QAAA,CAAAC,IAAI;;IAEPC,MAAM,EAAAC,QAAA,CACf,MAAkE,CAAlElB,YAAA,CAAkEmB,oBAAA;MAAtDC,OAAK,EAAEL,QAAA,CAAAC;IAAI;wBAAE,MAA6B,CAA7BhB,YAAA,CAA6BC,kBAAA;0BAApB,MAAU,CAAVD,YAAA,CAAUqB,iBAAA,E;;;;;;kDAKlDzB,mBAAA,CAoBM,OApBN0B,UAoBM,G,+BAnBJC,YAAA,CAkBWC,mBAAA;IAlBoBC,IAAI,EAAEtB,KAAA,CAAAuB,SAAS;IAAEC,MAAM,EAAN,EAAM;IAACC,MAAM,EAAN,EAAM;IAACC,KAAmB,EAAnB;MAAA;IAAA;;sBAC5D,MAAoF,CAApF7B,YAAA,CAAoF8B,0BAAA;MAAnEC,IAAI,EAAC,OAAO;MAAIC,KAAK,EAAC,IAAI;MAAC,WAAS,EAAC,KAAK;MAAC,uBAAqB,EAArB;QAC5DhC,YAAA,CAIkB8B,0BAAA;MAJDE,KAAK,EAAC,IAAI;MAAG,WAAS,EAAC;;MAC3BC,OAAO,EAAAf,QAAA,CAAEgB,KAAK,KACvBtC,mBAAA,CAAuD,QAAvDuC,UAAuD,EAAA7B,gBAAA,CAA3B4B,KAAK