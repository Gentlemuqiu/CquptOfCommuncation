admin-page-header\">\n      <div class=\"page-header-left\">\n        <div class=\"page-header-icon purple\">\n          <el-icon><UserFilled /></el-icon>\n        </div>\n        <div>\n          <h2 class=\"page-header-title\">用户管理</h2>\n          <p class=\"page-header-desc\">管理注册用户，控制登录与评论权限</p>\n        </div>\n      </div>\n      <span class=\"page-header-badge\" v-if=\"total > 0\">\n        共 {{ total }} 位用户\n      </span>\n    </div>\n\n    <!-- 工具栏 -->\n    <div class=\"admin-toolbar\">\n      <el-input\n        v-model=\"search\"\n        placeholder=\"搜索用户名 / 昵称...\"\n        clearable\n        class=\"search-input\"\n        @keyup.enter=\"load\"\n      >\n        <template #append>\n          <el-button @click=\"load\"><el-icon><Search /></el-icon></el-button>\n        </template>\n      </el-input>\n    </div>\n\n    <!-- 表格 -->\n    <div class=\"admin-table-wrap\">\n      <el-table v-loading=\"loading\" :data=\"tableData\" border stripe style=\"width: 100%\">\n        <el-table-column prop=\"username\"  label=\"用户名\" min-width=\"110\" />\n        <el-table-column prop=\"nickName\"  label=\"昵称\"   min-width=\"110\" />\n        <el-table-column prop=\"phone\"     label=\"手机号\" width=\"130\" />\n        <el-table-column prop=\"age\"       label=\"年龄\"   width=\"70\" align=\"center\" />\n        <el-table-column prop=\"sex\"       label=\"性别\"   width=\"70\" align=\"center\" />\n        <el-table-column prop=\"address\"   label=\"地址\"   min-width=\"140\" show-overflow-tooltip />\n        <el-table-column label=\"禁止评论\" width=\"100\" align=\"center\">\n          <template #default=\"scope\">\n            <el-switch\n              v-model=\"scope.row.forbidComment\"\n              active-color=\"var(--danger-color)\"\n              inactive-color=\"#ddd\"\n              @change=\"change(scope.row, 'forbidComment')\"\n            />\n          </template>\n        </el-table-column>\n        <el-table-column label=\"禁止登录\" width=\"100\" align=\"center\">\n          <template #default=\"scope\">\n            <el-switch\n              v-model=\"scope.row.forbidLogin\"\n              active-color=\"var(--danger-color)\"\n              inactive-color=\"#ddd\"\n              @change=\"change(scope.row, 'forbidLogin')\"\n            />\n          </template>\n        </el-table-column>\n        <el-table-column label=\"操作\" width=\"90\" align=\"center\" fixed=\"right\">\n          <template #default=\"scope\">\n            <el-popconfirm title=\"确定删除该用户吗？\" @confirm=\"handleDelete(scope.row.id)\">\n              <template #reference>\n                <el-button size=\"small\" type=\"danger\">删除</el-button>\n              </template>\n            </el-popconfirm>\n          </template>\n        </el-table-column>\n      </el-table>\n    </div>\n\n    <el-empty v-if=\"!loading && tableData.length === 0\" description=\"暂无数据\" />\n\n    <!-- 分页 -->\n    <div class=\"admin-pagination\">\n      <el-pagination\n        @size-change=\"handleSizeChange\"\n        @current-change=\"handleCurrentChange\"\n        :current-page=\"pageNum\"\n        :page-sizes=\"[10, 20, 50]\"\n        :page-size=\"pageSize\"\n        layout=\"total, sizes, prev, pager, next\"\n        :total=\"total\"\n      />\n    </div>\n  </div>\n</template>\n\n<script>\nimport { getUserPage, updateUser, deleteUser } from '@/api/user'\nimport { UserFilled, Search } from '@element-plus/icons-vue'\n\nexport default {\n  name: 'User',\n  components: { UserFilled, Search },\n  data() {\n    return {\n      loading: false,\n      search: '',\n      pageNum: 1,\n      pageSize: 10,\n      total: 0,\n      tableData: [],\n    }\n  },\n  created() {\n    this.load()\n  },\n  methods: {\n    load() {\n      this.loading = true\n      getUserPage({\n        pageNum: this.pageNum,\n        pageSize: this.pageSize,\n        search: this.search\n      })\n        .then(res => {\n          this.tableData = (res.data.records || []).filter(item => item.role !== 1)\n          this.total = this.tableData.length\n        })\n        .catch(() => {})\n        .finally(() => { this.loading = false })\n    },\n    handleDelete(id) {\n      deleteUser(id).then(res => {\n        if (res.code === '0') {\n          this.$message.success('删除成功')\n          this.load()\n        } else {\n          this.$message.error(res.msg)\n        }\n      })\n    },\n    change(row, field) {\n      updateUser(row).then(res => {\n        if (res.code === '0') {\n          this.$message.success(field === 'forbidComment' ? '评论权限已更新' : '登录权限已更新')\n        } else {\n          this.$message.error(res.msg)\n        }\n      })\n    },\n    handleSizeChange(ps) {\n      this.pageSize = ps\n      this.load()\n    },\n    handleCurrentChange(pn) {\n      this.pageNum = pn\n      this.load()\n    },\n  }\n}\n</script>\n\n<style scoped></style>\n"],"mappings":";;AA4FA,SAASA,WAAW,EAAEC,UAAU,EAAEC,UAAS,QAAS,YAAW;AAC/D,SAASC,UAAU,EAAEC,MAAK,QAAS,yBAAwB;AAE3D,eAAe;EACbC,IAAI,EAAE,MAAM;EACZC,UAAU,EAAE;IAAEH,UAAU;IAAEC;EAAO,CAAC;EAClCG,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,KAAK;MACdC,MAAM,EAAE,EAAE;MACVC,OAAO,EAAE,CAAC;MACVC,QAAQ,EAAE,EAAE;MACZC,KAAK,EAAE,CAAC;MACRC,SAAS,EAAE;IACb;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,IAAI,CAAC;EACZ,CAAC;EACDC,OAAO,EAAE;IACPD,IAAIA,CAAA,EAAG;MACL,IAAI,CAACP,OAAM,GAAI,IAAG;MAClBR,WAAW,CAAC;QACVU,OAAO,EAAE,IAAI,CAACA,OAAO;QACrBC,QAAQ,EAAE,IAAI,CAACA,QAAQ;QACvBF,MAAM,EAAE,IAAI,CAACA;MACf,CAAC,EACEQ,IAAI,CAACC,GAAE,IAAK;QACX,IAAI,CAACL,SAAQ,GAAI,CAACK,GAAG,CAACX,IAAI,CAACY,OAAM,IAAK,EAAE,EAAEC,MAAM,CAACC,IAAG,IAAKA,IAAI,CAACC,IAAG,KAAM,CAAC;QACxE,IAAI,CAACV,KAAI,GAAI,IAAI,CAACC,SAAS,CAACU,MAAK;MACnC,CAAC,EACAC,KAAK,CAAC,MAAM,CAAC,CAAC,EACdC,OAAO,CAAC,MAAM;QAAE,IAAI,CAACjB,OAAM,GAAI,KAAI;MAAE,CAAC;IAC3C,CAAC;IACDkB,YAAYA,CAACC,EAAE,EAAE;MACfzB,UAAU,CAACyB,EAAE,CAAC,CAACV,IAAI,CAACC,GAAE,IAAK;QACzB,IAAIA,GAAG,CAACU,IAAG,KAAM,GAAG,EAAE;UACpB,IAAI,CAACC,QAAQ,CAACC,OAAO,CAAC,MAAM;UAC5B,IAAI,CAACf,IAAI,CAAC;QACZ,OAAO;UACL,IAAI,CAACc,QAAQ,CAACE,K