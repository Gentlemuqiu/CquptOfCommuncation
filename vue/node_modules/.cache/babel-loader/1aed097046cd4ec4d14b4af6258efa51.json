        </template>\n      </el-input>\n    </div>\n\n    <!-- 数据表格 -->\n    <div class=\"admin-table-wrap\">\n      <el-table\n        v-loading=\"loading\"\n        :data=\"tableData\"\n        border\n        stripe\n        style=\"width: 100%\"\n      >\n        <el-table-column prop=\"name\" label=\"标题\" min-width=\"160\" show-overflow-tooltip />\n        <el-table-column prop=\"description\" label=\"简介\" min-width=\"200\" show-overflow-tooltip />\n        <el-table-column prop=\"date\" label=\"发布日期\" width=\"120\" />\n        <el-table-column prop=\"area\" label=\"分类\" width=\"110\">\n          <template #default=\"scope\">\n            <el-tag size=\"small\" type=\"success\" effect=\"plain\">{{ scope.row.area }}</el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"赞/踩\" width=\"100\" align=\"center\">\n          <template #default=\"scope\">\n            <span style=\"color: var(--success-color)\">{{ scope.row.zan || 0 }}</span>\n            /\n            <span style=\"color: var(--danger-color)\">{{ scope.row.cai || 0 }}</span>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"封面\" width=\"90\" align=\"center\">\n          <template #default=\"scope\">\n            <el-image\n              style=\"width: 60px; height: 60px; border-radius: 6px\"\n              :src=\"scope.row.img\"\n              fit=\"cover\"\n              :preview-src-list=\"[scope.row.img]\"\n            />\n          </template>\n        </el-table-column>\n        <el-table-column label=\"操作\" width=\"140\" align=\"center\" fixed=\"right\">\n          <template #default=\"scope\">\n            <el-button size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\n            <el-popconfirm title=\"确定删除此条信息吗？\" @confirm=\"handleDelete(scope.row.id)\">\n              <template #reference>\n                <el-button size=\"small\" type=\"danger\">删除</el-button>\n              </template>\n            </el-popconfirm>\n          </template>\n        </el-table-column>\n      </el-table>\n    </div>\n\n    <el-empty v-if=\"!loading && tableData.length === 0\" description=\"暂无数据\" />\n\n    <!-- 分页 -->\n    <div class=\"admin-pagination\">\n      <el-pagination\n        @size-change=\"handleSizeChange\"\n        @current-change=\"handleCurrentChange\"\n        :current-page=\"pageNum\"\n        :page-sizes=\"[10, 20, 50]\"\n        :page-size=\"pageSize\"\n        layout=\"total, sizes, prev, pager, next\"\n        :total=\"total\"\n      />\n    </div>\n\n    <!-- 编辑弹框 -->\n    <el-dialog :title=\"entity.id ? '编辑信息' : '新增信息'\" v-model=\"dialogVisible\" width=\"560px\">\n      <el-form :model=\"entity\" :rules=\"rules\" ref=\"entityForm\" label-width=\"90px\" class=\"dialog-form\">\n        <el-form-item label=\"标题\" prop=\"name\">\n          <el-input v-model=\"entity.name\" placeholder=\"请输入标题\" clearable />\n        </el-form-item>\n        <el-form-item label=\"简介\" prop=\"description\">\n          <el-input\n            type=\"textarea\"\n            v-model=\"entity.description\"\n            placeholder=\"请输入简介\"\n            :rows=\"3\"\n          />\n        </el-form-item>\n        <el-form-item label=\"发布日期\" prop=\"date\">\n          <el-date-picker\n            style=\"width: 100%\"\n            v-model=\"entity.date\"\n            type=\"date\"\n            value-format=\"YYYY-MM-DD\"\n            placeholder=\"选择日期\"\n          />\n        </el-form-item>\n        <el-form-item label=\"分类\" prop=\"area\">\n          <el-select v-model=\"entity.area\" placeholder=\"请选择分类\" clearable style=\"width: 100%\">\n            <el-option\n              v-for=\"item in AREAS\"\n              :key=\"item\"\n              :label=\"item\"\n              :value=\"item\"\n            />\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"封面图片\">\n          <el-upload\n            :action=\"uploadUrl\"\n            :on-success=\"fileSuccessUpload\"\n            :file-list=\"fileList\"\n            :limit=\"1\"\n            list-type=\"picture\"\n          >\n            <el-button type=\"default\">\n              <el-icon><Upload /></el-icon>上传图片\n            </el-button>\n          </el-upload>\n        </el-form-item>\n      </el-form>\n      <template #footer>\n        <el-button @click=\"dialogVisible = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"save\">保 存</el-button>\n      </template>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { getMoviePage, createMovie, updateMovie, deleteMovie } from '@/api/movie'\nimport { INFO_AREAS } from '@/config/navigation'\nimport { Document, Plus, Search, Upload } from '@element-plus/icons-vue'\n\nconst UPLOAD_URL = (process.env.VUE_APP_BASEURL || '/api') + '/files/upload'\n\nexport default {\n  name: 'Sayings',\n  components: { Document, Plus, Search, Upload },\n  data() {\n    return {\n      AREAS: INFO_AREAS.map(a => a.key),\n      uploadUrl: UPLOAD_URL,\n      loading: false,\n      entity: {},\n      dialogVisible: false,\n      search: '',\n      pageNum: 1,\n      pageSize: 10,\n      total: 0,\n      tableData: [],\n      fileList: [],\n      rules: {\n        name: [{ required: true, message: '请输入标题', trigger: 'blur' }],\n        description: [{ required: true, message: '请输入简介', trigger: 'blur' }],\n        date: [{ required: true, message: '请选择发布日期', trigger: 'change' }],\n        area: [{ required: true, message: '请选择分类', trigger: 'change' }],\n      }\n    }\n  },\n  created() {\n    this.load()\n  },\n  methods: {\n    load() {\n      this.loading = true\n      getMoviePage({\n        pageNum: this.pageNum,\n        pageSize: this.pageSize,\n        search: this.search\n      })\n        .then(res => {\n          this.tableData = res.data.records || []\n          this.total = res.data.total || 0\n        })\n        .catch(() => {})\n        .finally(() => { this.loading = false })\n    },\n    add() {\n      this.entity = { name: '', description: '', date: '', area: '', img: '' }\n      this.fileList = []\n      this.dialogVisible = true\n    },\n    save() {\n      this.$refs.entityForm.validate(valid => {\n        if (!valid) return\n        const fn = this.entity.id ? updateMovie : createMovie\n        fn(this.entity).then(res => {\n          if (res.code === '0') {\n            this.$message.success(this.entity.id ? '更新成功' : '新增成功')\n            this.load()\n            this.dialogVisible = false\n          } else {\n            this.$message.error(res.msg)\n          }\n        })\n      })\n    },\n    handleEdit(row) {\n      this.entity = { ...row }\n      this.fileList = []\n      this.dialogVisible = true\n    },\n    handleDelete(id) {\n      deleteMovie(id).then(() => {\n        this.$message.success('删除成功')\n        this.load()\n      })\n    },\n    fileSuccessUpload(res) {\n      this.entity.img = res.data\n    },\n    handleSizeChange(pageSize) {\n      this.pageSize = pageSize\n      this.load()\n    },\n    handleCurrentChange(pageNum) {\n      this.pageNum = pageNum\n      this.load()\n    },\n  }\n}\n</script>\n\n<style scoped></style>\n"],"mappings":";;EACOA,KAAK,EAAC;AAAY;;EAEhBA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAAkB;;EACtBA,KAAK,EAAC;AAAkB;;;EAQzBA,KAAK,EAAC;;;EAMTA,KAAK,EAAC;AAAe;;EAkBrBA,KAAK,EAAC;AAAkB;;EAkBfC,KAAmC,EAAnC;IAAA;EAAA;AAAmC;;EAEnCA,KAAkC,EAAlC;IAAA;EAAA;AAAkC;;EA6B3CD,KAAK,EAAC;AAAkB;;;;;;;;;;;;;;;;;;;;;;;;uBArF/BE,mBAAA,CAqJM,OArJNC,UAqJM,GApJJC,mBAAA,UAAa,EACbC,mBAAA,CAaM,OAbNC,UAaM,GAZJD,mBAAA,CAQM,OARNE,UAQM,GAPJF,mBAAA,CAEM,OAFNG,UAEM,GADJC,YAAA,CAA+BC,kBAAA;sBAAtB,MAAY,CAAZD,YAAA,CAAYE,mBAAA,E;;kCAEvBN,mBAAA,CAGM,cAFJA,mBAAA,CAAuC;IAAnCL,KAAK,EAAC;EAAmB,GAAC,MAAI,GAClCK,mBAAA,CAAmD;IAAhDL,KAAK,EAAC;EAAkB,GAAC,qBAAmB,E,wBAGbY,KAAA,CAAAC,KAAK,Q,cAA3CX,mBAAA,CAEO,QAFPY,UAEO,EAF0C,KAC7C,GAAAC,gBAAA,CAAGH,KAAA,CAAAC,KAAK,IAAG,OACf,mB,qCAGFT,mBAAA,SAAY,EACZC,mBAAA,CAeM,OAfNW,UAeM,GAdJP,YAAA,CAEYQ,oBAAA;IAFDC,IAAI,EAAC,SAAS;IAAEC,OAAK