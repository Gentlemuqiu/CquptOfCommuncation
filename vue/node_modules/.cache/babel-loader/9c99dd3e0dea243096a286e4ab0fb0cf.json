{"remainingRequest":"C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\node_modules\\babel-loader\\lib\\index.js!C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\node_modules\\vue-loader-v16\\dist\\index.js??ref--1-1!C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\src\\views\\front\\LittleSaying.vue?vue&type=script&lang=js","dependencies":[{"path":"C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\src\\views\\front\\LittleSaying.vue","mtime":1773571916820},{"path":"C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\babel.config.js","mtime":1773487779960},{"path":"C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773487782028},{"path":"C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\node_modules\\babel-loader\\lib\\index.js","mtime":1773487781890},{"path":"C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773487782028},{"path":"C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\node_modules\\vue-loader-v16\\dist\\index.js","mtime":1773487789831}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["request","INFO_AREAS","EditPen","Document","Picture","InfoFilled","ArrowLeft","Promotion","UPLOAD_URL","process","env","VUE_APP_BASEURL","name","components","data","AREAS","uploadUrl","entity","description","date","area","img","postUserId","fileList","saving","rules","required","message","trigger","max","created","user","JSON","parse","sessionStorage","getItem","id","$message","warning","$router","push","methods","fileSuccessUpload","res","code","success","error","msg","handleUploadError","handleExceed","save","$refs","entityForm","validate","valid","post","cancel","back"],"sources":["C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\src\\views\\front\\LittleSaying.vue"],"sourcesContent":["<template>\r\n  <div class=\"page-bg\">\r\n    <div class=\"post-wrapper\">\r\n\r\n      <!-- в”Җв”Җ йЎ¶йғЁ Hero жЁӘе№… в”Җв”Җ -->\r\n      <div class=\"hero-banner\">\r\n        <div class=\"hero-icon-wrap\">\r\n          <el-icon class=\"hero-icon\"><EditPen /></el-icon>\r\n        </div>\r\n        <div class=\"hero-text\">\r\n          <h1>еҸ‘еёғе°ұдёҡдҝЎжҒҜ</h1>\r\n          <p>еҲҶдә«жӢӣиҒҳиө„и®ҜгҖҒжұӮиҒҢз»ҸйӘҢпјҢеё®еҠ©жӣҙеӨҡеҗҢеӯҰжүҫеҲ°зҗҶжғіе·ҘдҪң</p>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- в”Җв”Җ дё»иЎЁеҚ•еҚЎзүҮ в”Җв”Җ -->\r\n      <div class=\"post-card\">\r\n        <el-form\r\n          :model=\"entity\"\r\n          :rules=\"rules\"\r\n          ref=\"entityForm\"\r\n          label-position=\"top\"\r\n          class=\"post-form\"\r\n        >\r\n\r\n          <!-- в”Җ з»„пјҡеҹәжң¬дҝЎжҒҜ в”Җ -->\r\n          <div class=\"group-label\">\r\n            <span class=\"group-dot\"></span>\r\n            еҹәжң¬дҝЎжҒҜ\r\n          </div>\r\n\r\n          <!-- ж Үйўҳ -->\r\n          <el-form-item label=\"дҝЎжҒҜж Үйўҳ\" prop=\"name\">\r\n            <el-input\r\n              v-model=\"entity.name\"\r\n              placeholder=\"иҜ·иҫ“е…ҘдҝЎжҒҜж ҮйўҳпјҢз®ҖжҙҒжҳҺдәҶпјҲдёҚи¶…иҝҮ 50 еӯ—пјү\"\r\n              maxlength=\"50\"\r\n              show-word-limit\r\n              clearable\r\n              size=\"large\"\r\n              class=\"title-input\"\r\n            >\r\n              <template #prefix>\r\n                <el-icon><Document /></el-icon>\r\n              </template>\r\n            </el-input>\r\n          </el-form-item>\r\n\r\n          <!-- еҲҶзұ» + ж—Ҙжңҹ дёӨеҲ— -->\r\n          <div class=\"form-row\">\r\n            <el-form-item label=\"дҝЎжҒҜеҲҶзұ»\" prop=\"area\" class=\"form-col\">\r\n              <div class=\"area-cards\">\r\n                <div\r\n                  v-for=\"item in AREAS\"\r\n                  :key=\"item.key\"\r\n                  class=\"area-card\"\r\n                  :class=\"{ active: entity.area === item.key }\"\r\n                  @click=\"entity.area = item.key\"\r\n                >\r\n                  <span class=\"area-emoji\">{{ item.icon }}</span>\r\n                  <span class=\"area-label\">{{ item.label }}</span>\r\n                </div>\r\n              </div>\r\n            </el-form-item>\r\n\r\n            <el-form-item label=\"еҸ‘еёғж—Ҙжңҹ\" prop=\"date\" class=\"form-col date-col\">\r\n              <el-date-picker\r\n                v-model=\"entity.date\"\r\n                type=\"date\"\r\n                value-format=\"YYYY-MM-DD\"\r\n                placeholder=\"йҖүжӢ©еҸ‘еёғж—Ҙжңҹ\"\r\n                style=\"width: 100%\"\r\n                size=\"large\"\r\n              />\r\n            </el-form-item>\r\n          </div>\r\n\r\n          <!-- в”Җ з»„пјҡиҜҰз»ҶеҶ…е®№ в”Җ -->\r\n          <div class=\"group-label\">\r\n            <span class=\"group-dot\"></span>\r\n            иҜҰз»ҶеҶ…е®№\r\n          </div>\r\n\r\n          <!-- з®Җд»Ӣ -->\r\n          <el-form-item label=\"дҝЎжҒҜз®Җд»Ӣ\" prop=\"description\">\r\n            <el-input\r\n              type=\"textarea\"\r\n              v-model=\"entity.description\"\r\n              placeholder=\"иҜ·з®ҖиҰҒжҸҸиҝ°иҜҘдҝЎжҒҜзҡ„дё»иҰҒеҶ…е®№пјҢеҢ…жӢ¬еІ—дҪҚиҰҒжұӮгҖҒи–Әиө„еҫ…йҒҮгҖҒз”іиҜ·ж–№ејҸзӯү...\"\r\n              :rows=\"5\"\r\n              maxlength=\"300\"\r\n              show-word-limit\r\n              class=\"desc-textarea\"\r\n            />\r\n          </el-form-item>\r\n\r\n          <!-- в”Җ з»„пјҡе°ҒйқўеӣҫзүҮ в”Җ -->\r\n          <div class=\"group-label\">\r\n            <span class=\"group-dot\"></span>\r\n            е°ҒйқўеӣҫзүҮ\r\n            <span class=\"optional-badge\">йҖүеЎ«</span>\r\n          </div>\r\n\r\n          <el-form-item>\r\n            <!-- е·ІдёҠдј йў„и§Ҳ -->\r\n            <div v-if=\"entity.img\" class=\"img-preview-card\">\r\n              <img :src=\"entity.img\" alt=\"е°Ғйқўйў„и§Ҳ\" class=\"preview-img\" />\r\n              <div class=\"preview-info\">\r\n                <div class=\"preview-title\">е°Ғйқўе·ІдёҠдј </div>\r\n                <div class=\"preview-sub\">зӮ№еҮ»еҸідҫ§жҢүй’®еҸҜжӣҝжҚўжҲ–з§»йҷӨ</div>\r\n                <div class=\"preview-actions\">\r\n                  <el-upload\r\n                    action=\"http://localhost:8080/files/upload\"\r\n                    :on-success=\"fileSuccessUpload\"\r\n                    :on-error=\"handleUploadError\"\r\n                    :file-list=\"fileList\"\r\n                    :limit=\"1\"\r\n                    :on-exceed=\"handleExceed\"\r\n                    accept=\"image/*\"\r\n                    :show-file-list=\"false\"\r\n                  >\r\n                    <el-button size=\"small\" type=\"primary\" plain>йҮҚж–°дёҠдј </el-button>\r\n                  </el-upload>\r\n                  <el-button\r\n                    size=\"small\"\r\n                    type=\"danger\"\r\n                    plain\r\n                    @click=\"entity.img = ''; fileList = []\"\r\n                  >\r\n                    з§»йҷӨеӣҫзүҮ\r\n                  </el-button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <!-- жңӘдёҠдј ж—¶зҡ„дёҠдј еҢәеҹҹ -->\r\n            <el-upload\r\n              v-else\r\n              action=\"http://localhost:8080/files/upload\"\r\n              :on-success=\"fileSuccessUpload\"\r\n              :on-error=\"handleUploadError\"\r\n              :file-list=\"fileList\"\r\n              :limit=\"1\"\r\n              :on-exceed=\"handleExceed\"\r\n              accept=\"image/*\"\r\n              :show-file-list=\"false\"\r\n              drag\r\n              class=\"upload-dragger\"\r\n            >\r\n              <div class=\"upload-inner\">\r\n                <el-icon class=\"upload-icon\"><Picture /></el-icon>\r\n                <div class=\"upload-title\">жӢ–жӢҪеӣҫзүҮеҲ°жӯӨеӨ„пјҢжҲ– <span class=\"upload-link\">зӮ№еҮ»дёҠдј </span></div>\r\n                <div class=\"upload-hint\">ж”ҜжҢҒ JPG / PNG / GIF В· е»әи®®е°әеҜё 800Г—450 В· жңҖеӨ§ 5MB</div>\r\n              </div>\r\n            </el-upload>\r\n          </el-form-item>\r\n\r\n          <!-- в”Җ еә•йғЁж“ҚдҪңж Ҹ в”Җ -->\r\n          <div class=\"form-footer\">\r\n            <div class=\"footer-tip\">\r\n              <el-icon><InfoFilled /></el-icon>\r\n              <span>еҸ‘еёғеҗҺеҶ…е®№е°Ҷз»ҸиҝҮе®Ўж ёпјҢиҜ·зЎ®дҝқдҝЎжҒҜзңҹе®һжңүж•Ҳ</span>\r\n            </div>\r\n            <div class=\"form-actions\">\r\n              <el-button class=\"cancel-btn\" @click=\"cancel\">\r\n                <el-icon><ArrowLeft /></el-icon>\r\n                иҝ”еӣһ\r\n              </el-button>\r\n              <el-button\r\n                type=\"primary\"\r\n                class=\"publish-btn\"\r\n                @click=\"save\"\r\n                :loading=\"saving\"\r\n              >\r\n                <el-icon v-if=\"!saving\"><Promotion /></el-icon>\r\n                {{ saving ? 'еҸ‘еёғдёӯ...' : 'з«ӢеҚіеҸ‘еёғ' }}\r\n              </el-button>\r\n            </div>\r\n          </div>\r\n\r\n        </el-form>\r\n      </div>\r\n\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from \"@/utils/request\";\r\nimport { INFO_AREAS } from \"@/config/navigation\";\r\nimport {\r\n  EditPen, Document, Picture, InfoFilled, ArrowLeft, Promotion\r\n} from '@element-plus/icons-vue'\r\n\r\nconst UPLOAD_URL = (process.env.VUE_APP_BASEURL || '/api') + '/files/upload';\r\n\r\nexport default {\r\n  name: \"LittleSaying\",\r\n  components: { EditPen, Document, Picture, InfoFilled, ArrowLeft, Promotion },\r\n  data() {\r\n    return {\r\n      AREAS: INFO_AREAS,\r\n      uploadUrl: UPLOAD_URL,\r\n      entity: {\r\n        name: \"\",\r\n        description: \"\",\r\n        date: \"\",\r\n        area: \"\",\r\n        img: \"\",\r\n        postUserId: null\r\n      },\r\n      fileList: [],\r\n      saving: false,\r\n      rules: {\r\n        name: [\r\n          { required: true, message: \"иҜ·иҫ“е…Ҙж Үйўҳ\", trigger: \"blur\" },\r\n          { max: 50, message: \"ж ҮйўҳдёҚиғҪи¶…иҝҮ 50 еӯ—\", trigger: \"blur\" }\r\n        ],\r\n        description: [\r\n          { required: true, message: \"иҜ·иҫ“е…Ҙз®Җд»Ӣ\", trigger: \"blur\" }\r\n        ],\r\n        date: [{ required: true, message: \"иҜ·йҖүжӢ©еҸ‘еёғж—Ҙжңҹ\", trigger: \"change\" }],\r\n        area: [{ required: true, message: \"иҜ·йҖүжӢ©еҲҶзұ»\", trigger: \"change\" }],\r\n      }\r\n    };\r\n  },\r\n  created() {\r\n    const user = JSON.parse(sessionStorage.getItem(\"user\") || \"{}\");\r\n    if (!user.id) {\r\n      this.$message.warning(\"иҜ·е…Ҳзҷ»еҪ•еҗҺеҶҚеҸ‘еёғдҝЎжҒҜ\");\r\n      this.$router.push(\"/login\");\r\n      return;\r\n    }\r\n    this.entity.postUserId = user.id;\r\n  },\r\n  methods: {\r\n    fileSuccessUpload(res) {\r\n      if (res.code === '0') {\r\n        this.entity.img = res.data;\r\n        this.$message.success('е°ҒйқўеӣҫзүҮдёҠдј жҲҗеҠҹ');\r\n      } else {\r\n        this.$message.error(res.msg || 'еӣҫзүҮдёҠдј еӨұиҙҘ');\r\n      }\r\n    },\r\n    handleUploadError() {\r\n      this.$message.error('дёҠдј еӨұиҙҘпјҢиҜ·жЈҖжҹҘзҪ‘з»ңжҲ–ж–Үд»¶еӨ§е°Ҹ');\r\n    },\r\n    handleExceed() {\r\n      this.$message.warning('е·Іжңүж–Үд»¶пјҢиҜ·е…ҲеҲ йҷӨеҗҺеҶҚдёҠдј ');\r\n    },\r\n    save() {\r\n      this.$refs.entityForm.validate(async (valid) => {\r\n        if (!valid) return;\r\n        this.saving = true;\r\n        try {\r\n          const res = await request.post(\"/movie\", this.entity);\r\n          if (res.code === '0') {\r\n            this.$message.success(\"еҸ‘еёғжҲҗеҠҹпјҒ\");\r\n            this.$router.push('/front/home');\r\n          } else {\r\n            this.$message.error(res.msg || 'еҸ‘еёғеӨұиҙҘпјҢиҜ·зЁҚеҗҺйҮҚиҜ•');\r\n          }\r\n        } catch {\r\n          this.$message.error(\"зҪ‘з»ңй”ҷиҜҜпјҢиҜ·зЁҚеҗҺйҮҚиҜ•\");\r\n        } finally {\r\n          this.saving = false;\r\n        }\r\n      });\r\n    },\r\n    cancel() {\r\n      this.$router.back();\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\r\n   йЎөйқўиғҢжҷҜ\r\nв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ */\r\n.page-bg {\r\n  min-height: calc(100vh - 64px);\r\n  background: var(--bg-page);\r\n  padding: var(--spacing-xl) var(--spacing-xl) var(--spacing-3xl);\r\n}\r\n\r\n.post-wrapper {\r\n  max-width: 800px;\r\n  margin: 0 auto;\r\n}\r\n\r\n/* в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\r\n   йЎ¶йғЁ Hero жЁӘе№…\r\nв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ */\r\n.hero-banner {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--spacing-lg);\r\n  background: var(--primary-gradient);\r\n  border-radius: var(--radius-xl);\r\n  padding: var(--spacing-xl) var(--spacing-2xl);\r\n  margin-bottom: var(--spacing-xl);\r\n  box-shadow: var(--shadow-primary);\r\n  position: relative;\r\n  overflow: hidden;\r\n}\r\n\r\n.hero-banner::before {\r\n  content: '';\r\n  position: absolute;\r\n  top: -40px;\r\n  right: -40px;\r\n  width: 160px;\r\n  height: 160px;\r\n  border-radius: 50%;\r\n  background: rgba(255, 255, 255, 0.06);\r\n}\r\n\r\n.hero-banner::after {\r\n  content: '';\r\n  position: absolute;\r\n  bottom: -60px;\r\n  right: 80px;\r\n  width: 220px;\r\n  height: 220px;\r\n  border-radius: 50%;\r\n  background: rgba(255, 255, 255, 0.04);\r\n}\r\n\r\n.hero-icon-wrap {\r\n  width: 60px;\r\n  height: 60px;\r\n  border-radius: var(--radius-lg);\r\n  background: rgba(255, 255, 255, 0.15);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  flex-shrink: 0;\r\n  backdrop-filter: blur(4px);\r\n  border: 1px solid rgba(255, 255, 255, 0.2);\r\n}\r\n\r\n.hero-icon {\r\n  font-size: 28px;\r\n  color: #ffffff;\r\n}\r\n\r\n.hero-text h1 {\r\n  margin: 0 0 6px;\r\n  font-size: var(--font-size-2xl);\r\n  font-weight: var(--font-weight-bold);\r\n  color: #ffffff;\r\n  letter-spacing: 0.02em;\r\n}\r\n\r\n.hero-text p {\r\n  margin: 0;\r\n  font-size: var(--font-size-sm);\r\n  color: rgba(255, 255, 255, 0.78);\r\n  line-height: var(--line-height-snug);\r\n}\r\n\r\n/* в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\r\n   дё»еҚЎзүҮ\r\nв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ */\r\n.post-card {\r\n  background: var(--bg-primary);\r\n  border: 1px solid var(--border-lighter);\r\n  border-radius: var(--radius-xl);\r\n  padding: var(--spacing-2xl);\r\n  box-shadow: var(--shadow-base);\r\n  transition: box-shadow var(--transition-base);\r\n}\r\n\r\n.post-card:hover {\r\n  box-shadow: var(--shadow-md);\r\n}\r\n\r\n/* в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\r\n   еҲҶз»„ж Үйўҳ\r\nв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ */\r\n.group-label {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--spacing-sm);\r\n  font-size: var(--font-size-xs);\r\n  font-weight: var(--font-weight-semibold);\r\n  color: var(--primary-color);\r\n  text-transform: uppercase;\r\n  letter-spacing: 0.08em;\r\n  margin: var(--spacing-xl) 0 var(--spacing-base);\r\n}\r\n\r\n.group-label:first-child {\r\n  margin-top: 0;\r\n}\r\n\r\n.group-dot {\r\n  width: 6px;\r\n  height: 6px;\r\n  border-radius: 50%;\r\n  background: var(--primary-gradient);\r\n  flex-shrink: 0;\r\n}\r\n\r\n.optional-badge {\r\n  font-size: var(--font-size-xs);\r\n  color: var(--text-disabled);\r\n  background: var(--bg-tertiary);\r\n  padding: 1px 8px;\r\n  border-radius: var(--radius-full);\r\n  font-weight: var(--font-weight-normal);\r\n  letter-spacing: normal;\r\n  text-transform: none;\r\n}\r\n\r\n/* в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\r\n   иЎЁеҚ•ж ·ејҸ\r\nв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ */\r\n.post-form :deep(.el-form-item__label) {\r\n  font-size: var(--font-size-sm);\r\n  font-weight: var(--font-weight-semibold);\r\n  color: var(--text-secondary);\r\n  margin-bottom: 6px;\r\n  padding-bottom: 0;\r\n  line-height: 1.4;\r\n}\r\n\r\n.post-form :deep(.el-input__wrapper) {\r\n  border-radius: var(--radius-base);\r\n  transition: box-shadow var(--transition-fast);\r\n}\r\n\r\n.post-form :deep(.el-input__wrapper:hover) {\r\n  box-shadow: 0 0 0 1px var(--primary-lighter) inset;\r\n}\r\n\r\n.post-form :deep(.el-input__wrapper.is-focus) {\r\n  box-shadow: 0 0 0 1px var(--primary-color) inset !important;\r\n}\r\n\r\n.post-form :deep(.el-textarea__inner) {\r\n  border-radius: var(--radius-base);\r\n  font-size: var(--font-size-base);\r\n  line-height: var(--line-height-relaxed);\r\n  resize: vertical;\r\n}\r\n\r\n.title-input :deep(.el-input__inner) {\r\n  font-size: var(--font-size-md);\r\n  font-weight: var(--font-weight-medium);\r\n}\r\n\r\n/* в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\r\n   дёӨеҲ—еёғеұҖ\r\nв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ */\r\n.form-row {\r\n  display: grid;\r\n  grid-template-columns: 1fr 240px;\r\n  gap: var(--spacing-lg);\r\n  align-items: start;\r\n}\r\n\r\n.date-col :deep(.el-date-editor) {\r\n  border-radius: var(--radius-base);\r\n}\r\n\r\n/* в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\r\n   еҲҶзұ»еҚЎзүҮйҖүжӢ©еҷЁ\r\nв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ */\r\n.area-cards {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: var(--spacing-sm);\r\n}\r\n\r\n.area-card {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  gap: 4px;\r\n  padding: var(--spacing-sm) var(--spacing-base);\r\n  min-width: 72px;\r\n  border: 1.5px solid var(--border-light);\r\n  border-radius: var(--radius-base);\r\n  cursor: pointer;\r\n  background: var(--bg-secondary);\r\n  transition: all var(--transition-fast);\r\n  user-select: none;\r\n}\r\n\r\n.area-card:hover {\r\n  border-color: var(--primary-lighter);\r\n  background: var(--bg-hover);\r\n  transform: translateY(-1px);\r\n  box-shadow: var(--shadow-sm);\r\n}\r\n\r\n.area-card.active {\r\n  border-color: var(--primary-color);\r\n  background: var(--primary-gradient-soft);\r\n  box-shadow: 0 0 0 3px rgba(15, 118, 110, 0.12);\r\n}\r\n\r\n.area-emoji {\r\n  font-size: 20px;\r\n  line-height: 1;\r\n}\r\n\r\n.area-label {\r\n  font-size: var(--font-size-xs);\r\n  font-weight: var(--font-weight-medium);\r\n  color: var(--text-secondary);\r\n  white-space: nowrap;\r\n}\r\n\r\n.area-card.active .area-label {\r\n  color: var(--primary-dark);\r\n  font-weight: var(--font-weight-semibold);\r\n}\r\n\r\n/* в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\r\n   дёҠдј еҢәеҹҹ\r\nв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ */\r\n.upload-dragger {\r\n  width: 100%;\r\n}\r\n\r\n.upload-dragger :deep(.el-upload) {\r\n  width: 100%;\r\n}\r\n\r\n.upload-dragger :deep(.el-upload-dragger) {\r\n  width: 100%;\r\n  height: 140px;\r\n  border-radius: var(--radius-lg);\r\n  border: 2px dashed var(--border-base);\r\n  background: var(--bg-secondary);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  transition: a