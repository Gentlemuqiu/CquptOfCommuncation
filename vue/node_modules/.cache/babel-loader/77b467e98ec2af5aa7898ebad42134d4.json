{"remainingRequest":"C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\node_modules\\babel-loader\\lib\\index.js!C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\node_modules\\vue-loader-v16\\dist\\index.js??ref--1-1!C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\src\\views\\notice.vue?vue&type=script&lang=js","dependencies":[{"path":"C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\src\\views\\notice.vue","mtime":1773583139551},{"path":"C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\babel.config.js","mtime":1773487779960},{"path":"C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773487782028},{"path":"C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\node_modules\\babel-loader\\lib\\index.js","mtime":1773487781890},{"path":"C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773487782028},{"path":"C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\node_modules\\vue-loader-v16\\dist\\index.js","mtime":1773487789831}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["request","Bell","Plus","Check","name","components","data","loading","entity","dialogVisible","pageNum","pageSize","total","tableData","rules","required","message","trigger","content","created","load","methods","get","params","then","res","records","catch","add","save","$refs","form","validate","valid","method","id","code","$message","success","error","msg","handleEdit","row","handleDelete","delete","publish","status","put","handleSizeChange","ps","handleCurrentChange","pn"],"sources":["C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\src\\views\\notice.vue"],"sourcesContent":["<template>\n  <div class=\"admin-page\">\n    <!-- 页面标题 -->\n    <div class=\"admin-page-header\">\n      <div class=\"page-header-left\">\n        <div class=\"page-header-icon orange\">\n          <el-icon><Bell /></el-icon>\n        </div>\n        <div>\n          <h2 class=\"page-header-title\">公告管理</h2>\n          <p class=\"page-header-desc\">管理系统公告，支持草稿保存与一键发布</p>\n        </div>\n      </div>\n      <span class=\"page-header-badge\" v-if=\"total > 0\">\n        共 {{ total }} 条公告\n      </span>\n    </div>\n\n    <div class=\"admin-toolbar\">\n      <el-button type=\"primary\" @click=\"add\">\n        <el-icon><Plus /></el-icon>新增公告\n      </el-button>\n    </div>\n\n    <div class=\"admin-table-wrap\">\n      <el-table v-loading=\"loading\" :data=\"tableData\" border stripe style=\"width: 100%\">\n        <el-table-column prop=\"name\"    label=\"公告名称\" min-width=\"160\" />\n        <el-table-column prop=\"content\" label=\"公告内容\" min-width=\"280\" show-overflow-tooltip />\n        <el-table-column prop=\"time\"    label=\"发布时间\" width=\"160\" />\n        <el-table-column label=\"状态\" width=\"100\" align=\"center\">\n          <template #default=\"scope\">\n            <span :class=\"['status-tag', scope.row.status === '已发布' ? 'published' : 'draft']\">\n              {{ scope.row.status || '草稿' }}\n            </span>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"操作\" width=\"200\" align=\"center\" fixed=\"right\">\n          <template #default=\"scope\">\n            <el-button\n              size=\"small\"\n              type=\"success\"\n              :disabled=\"scope.row.status === '已发布'\"\n              @click=\"publish(scope.row)\"\n            >\n              <el-icon><Check /></el-icon>发布\n            </el-button>\n            <el-button size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\n            <el-popconfirm title=\"确定删除此公告吗？\" @confirm=\"handleDelete(scope.row.id)\">\n              <template #reference>\n                <el-button size=\"small\" type=\"danger\">删除</el-button>\n              </template>\n            </el-popconfirm>\n          </template>\n        </el-table-column>\n      </el-table>\n    </div>\n\n    <el-empty v-if=\"!loading && tableData.length === 0\" description=\"暂无公告\" />\n\n    <div class=\"admin-pagination\">\n      <el-pagination\n        @size-change=\"handleSizeChange\"\n        @current-change=\"handleCurrentChange\"\n        :current-page=\"pageNum\"\n        :page-sizes=\"[10, 20]\"\n        :page-size=\"pageSize\"\n        layout=\"total, sizes, prev, pager, next\"\n        :total=\"total\"\n      />\n    </div>\n\n    <!-- 弹框 -->\n    <el-dialog :title=\"entity.id ? '编辑公告' : '新增公告'\" v-model=\"dialogVisible\" width=\"500px\">\n      <el-form :model=\"entity\" :rules=\"rules\" ref=\"form\" label-width=\"80px\" class=\"dialog-form\">\n        <el-form-item label=\"名称\" prop=\"name\">\n          <el-input v-model=\"entity.name\" placeholder=\"请输入公告名称\" clearable />\n        </el-form-item>\n        <el-form-item label=\"内容\" prop=\"content\">\n          <el-input\n            type=\"textarea\"\n            v-model=\"entity.content\"\n            placeholder=\"请输入公告内容\"\n            :rows=\"4\"\n          />\n        </el-form-item>\n      </el-form>\n      <template #footer>\n        <el-button @click=\"dialogVisible = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"save\">确 定</el-button>\n      </template>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport request from \"@/utils/request\";\nimport { Bell, Plus, Check } from '@element-plus/icons-vue'\n\nexport default {\n  name: \"Notice\",\n  components: { Bell, Plus, Check },\n  data() {\n    return {\n      loading: false,\n      entity: {},\n      dialogVisible: false,\n      pageNum: 1,\n      pageSize: 10,\n      total: 0,\n      tableData: [],\n      rules: {\n        name:    [{ required: true, message: \"请输入公告名称\", trigger: \"blur\" }],\n        content: [{ required: true, message: \"请输入公告内容\", trigger: \"blur\" }],\n      },\n    };\n  },\n  created() { this.load(); },\n  methods: {\n    load() {\n      this.loading = true;\n      request.get(\"/notice/page\", {\n        params: { pageNum: this.pageNum, pageSize: this.pageSize }\n      }).then(res => {\n        this.loading = false;\n        this.tableData = res.data.records;\n        this.total = res.data.total;\n      }).catch(() => { this.loading = false; });\n    },\n    add() { this.entity = {}; this.dialogVisible = true; },\n    save() {\n      this.$refs.form.validate(valid => {\n        if (!valid) return;\n        const method = this.entity.id ? \"put\" : \"post\";\n        request[method](\"/notice\", this.entity).then(res => {\n          if (res.code === '0') {\n            this.$message.success(this.entity.id ? '更新成功' : '新增成功');\n            this.load();\n            this.dialogVisible = false;\n          } else {\n            this.$message.error(res.msg);\n          }\n        });\n      });\n    },\n    handleEdit(row) { this.entity = { ...row }; this.dialogVisible = true; },\n    handleDelete(id) {\n      request.delete(\"/notice/\" + id).then(res => {\n        if (res.code === '0') { this.$message.success('删除成功'); this.load(); }\n        else this.$message.error(res.msg);\n      });\n    },\n    publish(row) {\n      row.status = \"已发布\";\n      request.put(\"/notice\", row).then(res => {\n        if (res.code === '0') this.$message.success('发布成功');\n        else this.$message.error(res.msg);\n      });\n    },\n    handleSizeChange(ps) { this.pageSize = ps; this.load(); },\n    handleCurrentChange(pn) { this.pageNum = pn; this.load(); },\n  }\n};\n</script>\n\n<style scoped></style>\n"],"mappings":"AA+FA,OAAOA,OAAM,MAAO,iBAAiB;AACrC,SAASC,IAAI,EAAEC,IAAI,EAAEC,KAAI,QAAS,yBAAwB;AAE1D,eAAe;EACbC,IAAI,EAAE,QAAQ;EACdC,UAAU,EAAE;IAAEJ,IAAI;IAAEC,IAAI;IAAEC;EAAM,CAAC;EACjCG,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,KAAK;MACdC,MAAM,EAAE,CAAC,CAAC;MACVC,aAAa,EAAE,KAAK;MACpBC,OAAO,EAAE,CAAC;MACVC,QAAQ,EAAE,EAAE;MACZC,KAAK,EAAE,CAAC;MACRC,SAAS,EAAE,EAAE;MACbC,KAAK,EAAE;QACLV,IAAI,EAAK,CAAC;UAAEW,QAAQ,EAAE,IAAI;UAAEC,OAAO,