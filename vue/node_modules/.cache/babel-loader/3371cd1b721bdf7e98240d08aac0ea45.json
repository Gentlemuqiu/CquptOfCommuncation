|| '草稿' }}\n            </span>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"操作\" width=\"200\" align=\"center\" fixed=\"right\">\n          <template #default=\"scope\">\n            <el-button\n              size=\"small\"\n              type=\"success\"\n              :disabled=\"scope.row.status === '已发布'\"\n              @click=\"publish(scope.row)\"\n            >\n              <el-icon><Check /></el-icon>发布\n            </el-button>\n            <el-button size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\n            <el-popconfirm title=\"确定删除此公告吗？\" @confirm=\"handleDelete(scope.row.id)\">\n              <template #reference>\n                <el-button size=\"small\" type=\"danger\">删除</el-button>\n              </template>\n            </el-popconfirm>\n          </template>\n        </el-table-column>\n      </el-table>\n    </div>\n\n    <el-empty v-if=\"!loading && tableData.length === 0\" description=\"暂无公告\" />\n\n    <div class=\"admin-pagination\">\n      <el-pagination\n        @size-change=\"handleSizeChange\"\n        @current-change=\"handleCurrentChange\"\n        :current-page=\"pageNum\"\n        :page-sizes=\"[10, 20]\"\n        :page-size=\"pageSize\"\n        layout=\"total, sizes, prev, pager, next\"\n        :total=\"total\"\n      />\n    </div>\n\n    <!-- 弹框 -->\n    <el-dialog :title=\"entity.id ? '编辑公告' : '新增公告'\" v-model=\"dialogVisible\" width=\"500px\">\n      <el-form :model=\"entity\" :rules=\"rules\" ref=\"form\" label-width=\"80px\" class=\"dialog-form\">\n        <el-form-item label=\"名称\" prop=\"name\">\n          <el-input v-model=\"entity.name\" placeholder=\"请输入公告名称\" clearable />\n        </el-form-item>\n        <el-form-item label=\"内容\" prop=\"content\">\n          <el-input\n            type=\"textarea\"\n            v-model=\"entity.content\"\n            placeholder=\"请输入公告内容\"\n            :rows=\"4\"\n          />\n        </el-form-item>\n      </el-form>\n      <template #footer>\n        <el-button @click=\"dialogVisible = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"save\">确 定</el-button>\n      </template>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport request from \"@/utils/request\";\nimport { Bell, Plus, Check } from '@element-plus/icons-vue'\n\nexport default {\n  name: \"Notice\",\n  components: { Bell, Plus, Check },\n  data() {\n    return {\n      loading: false,\n      entity: {},\n      dialogVisible: false,\n      pageNum: 1,\n      pageSize: 10,\n      total: 0,\n      tableData: [],\n      rules: {\n        name:    [{ required: true, message: \"请输入公告名称\", trigger: \"blur\" }],\n        content: [{ required: true, message: \"请输入公告内容\", trigger: \"blur\" }],\n      },\n    };\n  },\n  created() { this.load(); },\n  methods: {\n    load() {\n      this.loading = true;\n      request.get(\"/notice/page\", {\n        params: { pageNum: this.pageNum, pageSize: this.pageSize }\n      }).then(res => {\n        this.loading = false;\n        this.tableData = res.data.records;\n        this.total = res.data.total;\n      }).catch(() => { this.loading = false; });\n    },\n    add() { this.entity = {}; this.dialogVisible = true; },\n    save() {\n      this.$refs.form.validate(valid => {\n        if (!valid) return;\n        const method = this.entity.id ? \"put\" : \"post\";\n        request[method](\"/notice\", this.entity).then(res => {\n          if (res.code === '0') {\n            this.$message.success(this.entity.id ? '更新成功' : '新增成功');\n            this.load();\n            this.dialogVisible = false;\n          } else {\n            this.$message.error(res.msg);\n          }\n        });\n      });\n    },\n    handleEdit(row) { this.entity = { ...row }; this.dialogVisible = true; },\n    handleDelete(id) {\n      request.delete(\"/notice/\" + id).then(res => {\n        if (res.code === '0') { this.$message.success('删除成功'); this.load(); }\n        else this.$message.error(res.msg);\n      });\n    },\n    publish(row) {\n      row.status = \"已发布\";\n      request.put(\"/notice\", row).then(res => {\n        if (res.code === '0') this.$message.success('发布成功');\n        else this.$message.error(res.msg);\n      });\n    },\n    handleSizeChange(ps) { this.pageSize = ps; this.load(); },\n    handleCurrentChange(pn) { this.pageNum = pn; this.load(); },\n  }\n};\n</script>\n\n<style scoped></style>\n"],"mappings":";;EACOA,KAAK,EAAC;AAAY;;EAEhBA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAAkB;;EACtBA,KAAK,EAAC;AAAyB;;;EAQhCA,KAAK,EAAC;;;EAKTA,KAAK,EAAC;AAAe;;EAMrBA,KAAK,EAAC;AAAkB;;EAmCxBA,KAAK,EAAC;AAAkB;;;;;;;;;;;;;;;;;uBA1D/BC,mBAAA,CA0FM,OA1FNC,UA0FM,GAzFJC,mBAAA,UAAa,EACbC,mBAAA,CAaM,OAbNC,UAaM,GAZJD,mBAAA,CAQM,OARNE,UAQM,GAPJF,mBAAA,CAEM,OAFNG,UAEM,GADJC,YAAA,CAA2BC,kBAAA;sBAAlB,MAAQ,CAARD,YAAA,CAAQE,eAAA,E;;kCAEnBN,mBAAA,CAGM,cAFJA,mBAAA,CAAuC;IAAnCJ,KAAK,EAAC;EAAmB,GAAC,MAAI,GAClCI,mBAAA,CAAkD;IAA/CJ,KAAK,EAAC;EAAkB,GAAC,oBAAkB,E,wBAGZW,KAAA,CAAAC,KAAK,Q,cAA3CX,mBAAA,CAEO,QAFPY,UAEO,EAF0C,KAC7C,GAAAC,gBAAA,CAAGH,KAAA,CAAAC,KAAK,IAAG,OACf,mB,qCAGFR,mBAAA,CAIM,OAJNW,UAIM,GAHJP,YAAA,CAEYQ,oBAAA;IAFDC,IAAI,EAAC,SAAS;IAAEC,OAAK,EAAEC,QAAA,CAAAC;;sBAChC,MAA2B,CAA3BZ,YAAA,CAA2BC,kBAAA;wBAAlB,MAAQ,CAARD,YAAA,CAAQa,eAAA,E;;mDAAU,OAC7B,G;;oCAGFjB,mBAAA,CA+BM,OA/BNkB,UA+BM,G,+BA9BJC,YAAA,CA6BWC,mBAAA;IA7BoBC,IAAI,EAAEd,KAAA,CAAAe,SAAS;IAAEC,MAAM,EAAN,EAAM;IAACC,MAAM,EAAN,EAAM;IAACC,KAAmB,EAAnB;MAAA;IAAA;;sBAC5D,MAA+D,CAA/DrB,YAAA,CAA+DsB,0BAAA;MAA9CC,IAAI,EAAC,MAAM;MAAIC,KAAK,EAAC,MAAM;MAAC,WAAS,EAAC;QACvDxB,YAAA,CAAqFsB,0BAAA;MAApEC,IAAI,EAAC,SAAS;MAACC,KAAK,EAAC,MAAM;MAAC,WAAS,EAAC,KAAK;MAAC,uBAAqB,EAArB;QAC7DxB,YAAA,CAA2DsB,0BAAA;MAA1CC,IAAI,EAAC,MAAM;MAAIC,KAAK,EAAC,MAAM;MAACC,KAAK,EAAC;QACnDzB,YAAA,CAMkBsB,0BAAA;MANDE,KAAK,EAAC,IAAI;MAACC,KAAK,EAAC,KAAK;MAACC,KAAK,EAAC;;MACjCC,OAAO,EAAAC,QAAA,CAAEC,KAAK,KACvBjC,mBAAA,CAEO;QAFAJ,KAAK,EAAAsC,eAAA,gBAAiBD,KAAK,CAACE,GAAG,CAACC,MAAM;0BACxCH,KAAK,CAACE,GAAG,CAACC,MAAM,gC;;QAIzBhC,YAAA,CAiBkB