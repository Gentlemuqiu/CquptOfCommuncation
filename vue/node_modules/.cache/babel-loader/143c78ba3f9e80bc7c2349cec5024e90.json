\n                  <h3>最新就业资讯</h3>\r\n                  <p>点击了解更多</p>\r\n                </div>\r\n              </div>\r\n            </a>\r\n          </el-carousel-item>\r\n        </el-carousel>\r\n\r\n        <!-- 分类按钮 -->\r\n        <div class=\"category-section\">\r\n          <div class=\"section-header\">\r\n            <h3 class=\"section-title\">\r\n              <i class=\"el-icon-menu\"></i>\r\n              信息分类\r\n            </h3>\r\n            <p class=\"section-desc\">选择您感兴趣的信息类别</p>\r\n          </div>\r\n          <div class=\"category-buttons\">\r\n            <el-button\r\n              v-for=\"item in areas\" :key=\"item\"\r\n              :class=\"{'active': item === activeArea}\"\r\n              @click=\"loadArea(1, item)\"\r\n              class=\"category-btn\"\r\n            >\r\n              <span class=\"btn-icon\">{{ getCategoryIcon(item) }}</span>\r\n              <span>{{ item }}</span>\r\n            </el-button>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 推荐列表 -->\r\n        <div class=\"recommendation-list\">\r\n          <el-row :gutter=\"15\">\r\n            <el-col :xs=\"24\" :sm=\"12\" :md=\"8\" :lg=\"6\" v-for=\"item in tableDataHot\" :key=\"item.id\">\r\n              <el-card class=\"recommend-card\" @click=\"$router.push('/front/detail?id=' + item.id)\">\r\n                <div class=\"card-image\">\r\n                  <el-image :src=\"item.img\" fit=\"cover\"></el-image>\r\n                </div>\r\n                <div class=\"card-title\">\r\n                  {{ item.name }}\r\n                </div>\r\n              </el-card>\r\n            </el-col>\r\n          </el-row>\r\n        </div>\r\n\r\n        <!-- 根据分类加载列表 -->\r\n        <div class=\"category-items\">\r\n          <el-row :gutter=\"15\" v-if=\"tableDataArea.length > 0\">\r\n            <el-col :xs=\"24\" :sm=\"12\" :md=\"8\" :lg=\"6\" v-for=\"item in tableDataArea\" :key=\"item.id\">\r\n              <el-card class=\"category-card\" @click=\"$router.push('/front/detail?id=' + item.id)\">\r\n                <div class=\"card-image\">\r\n                  <el-image :src=\"item.img\" fit=\"cover\"></el-image>\r\n                </div>\r\n                <div class=\"card-title\">\r\n                  {{ item.name }}\r\n                </div>\r\n              </el-card>\r\n            </el-col>\r\n          </el-row>\r\n\r\n          <div v-else class=\"no-data\">暂无数据...</div>\r\n\r\n          <!-- 分页 -->\r\n          <div class=\"pagination-container\">\r\n            <el-pagination\r\n                @size-change=\"handleSizeChange\"\r\n                @current-change=\"handleCurrentChange\"\r\n                :current-page=\"pageNum\"\r\n                :page-sizes=\"[5, 10, 20]\"\r\n                :page-size=\"pageSize\"\r\n                layout=\"prev, pager, next\"\r\n                :total=\"total\">\r\n            </el-pagination>\r\n          </div>\r\n        </div>\r\n\r\n      </el-col>\r\n    </el-row>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from \"@/utils/request\";\r\n\r\nexport default {\r\n  name: \"Home\",\r\n  data() {\r\n    return {\r\n      imgs: [\r\n        { img: require(\"@/assets/image/bg2.png\"), link: 'https://www.cqupt.edu.cn/' },\r\n        { img: require(\"@/assets/image/bg1.png\"), link: 'https://software.cqupt.edu.cn/' },\r\n        { img: require(\"@/assets/image/bg3.png\"), link: 'https://zjc.cqupt.edu.cn/' }\r\n      ],\r\n      tableDataArea: [],\r\n      tableDataHot: [],\r\n      areas: ['运动', '音乐', '剧情', '搞笑', '开胃'],\r\n      pageNum: 1,\r\n      pageSize: 12,\r\n      total: 0,\r\n      activeArea: ''\r\n    };\r\n  },\r\n  created() {\r\n    this.user = sessionStorage.getItem(\"user\") ? JSON.parse(sessionStorage.getItem(\"user\")) : {};\r\n    this.loadData();\r\n  },\r\n  methods: {\r\n    getLinkForItem(index) {\r\n      return this.imgs[index].link;\r\n    },\r\n    getCategoryIcon(category) {\r\n      const icons = {\r\n        '运动': '🏃',\r\n        '音乐': '🎵',\r\n        '剧情': '🎬',\r\n        '搞笑': '😄',\r\n        '开胃': '🍽️'\r\n      };\r\n      return icons[category] || '📋';\r\n    },\r\n    loadArea(pageNum, area) {\r\n      this.activeArea = area;\r\n      request.get(\"/movie/page/area\", {\r\n        params: { pageNum, pageSize: this.pageSize, area }\r\n      }).then(res => {\r\n        this.tableDataArea = res.data.records;\r\n        this.total = res.data.total;\r\n      });\r\n    },\r\n    loadData() {\r\n      this.loadArea(1, this.areas[0]); // 默认加载第一个区域\r\n    },\r\n    handleSizeChange(pageSize) {\r\n      this.pageSize = pageSize;\r\n      this.loadArea(1, this.activeArea);\r\n    },\r\n    handleCurrentChange(pageNum) {\r\n      this.pageNum = pageNum;\r\n      this.loadArea(pageNum, this.activeArea);\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.home-container {\r\n  padding: 0;\r\n  background: transparent;\r\n}\r\n\r\n/* 功能说明横幅 */\r\n.feature-banner {\r\n  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 50%, var(--primary-lighter) 100%);\r\n  padding: var(--spacing-2xl) 0;\r\n  margin-bottom: var(--spacing-xl);\r\n  border-radius: 0 0 var(--radius-xl) var(--radius-xl);\r\n  box-shadow: var(--shadow-primary);\r\n  position: relative;\r\n  overflow: hidden;\r\n}\r\n\r\n.feature-banner::before {\r\n  content: '';\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  right: 0;\r\n  bottom: 0;\r\n  background: radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.1) 0%, transparent 50%);\r\n  pointer-events: none;\r\n}\r\n\r\n.banner-content {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n  padding: 0 var(--spacing-lg);\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--spacing-2xl);\r\n  position: relative;\r\n  z-index: 1;\r\n}\r\n\r\n.banner-icon {\r\n  width: 88px;\r\n  height: 88px;\r\n  background: rgba(255, 255, 255, 0.2);\r\n  border-radius: var(--radius-lg);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  backdrop-filter: blur(10px);\r\n  border: 1px solid rgba(255, 255, 255, 0.3);\r\n  transition: all var(--transition-base);\r\n}\r\n\r\n.banner-icon:hover {\r\n  transform: scale(1.05) rotate(5deg);\r\n  background: rgba(255, 255, 255, 0.25);\r\n}\r\n\r\n.banner-icon i {\r\n  font-size: 44px;\r\n  color: #fff;\r\n}\r\n\r\n.banner-text {\r\n  flex: 1;\r\n  color: #fff;\r\n}\r\n\r\n.banner-text h2 {\r\n  font-size: var(--font-size-3xl);\r\n  font-weight: var(--font-weight-bold);\r\n  margin: 0 0 var(--spacing-sm) 0;\r\n  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);\r\n  letter-spacing: -0.5px;\r\n}\r\n\r\n.banner-text p {\r\n  font-size: var(--font-size-md);\r\n  margin: 0;\r\n  opacity: 0.95;\r\n  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.banner-features {\r\n  display: flex;\r\n  gap: var(--spacing-lg);\r\n}\r\n\r\n.feature-item {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  gap: var(--spacing-sm);\r\n  color: #fff;\r\n  padding: var(--spacing-base) var(--spacing-lg);\r\n  background: rgba(255, 255, 255, 0.15);\r\n  border-radius: var(--radius-md);\r\n  backdrop-filter: blur(10px);\r\n  border: 1px solid rgba(255, 255, 255, 0.2);\r\n  transition: all var(--transition-cubic);\r\n  cursor: pointer;\r\n}\r\n\r\n.feature-item:hover {\r\n  background: rgba(255, 255, 255, 0.25);\r\n  transform: translateY(-3px) scale(1.05);\r\n  box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.feature-item i {\r\n  font-size: var(--font-size-xl);\r\n}\r\n\r\n.feature-item span {\r\n  font-size: var(--font-size-sm);\r\n  font-weight: var(--font-weight-medium);\r\n}\r\n\r\n/* 轮播图样式优化 */\r\n.carousel-img-container {\r\n  position: relative;\r\n  width: 100%;\r\n  height: 100%;\r\n  border-radius: var(--radius-xl);\r\n  overflow: hidden;\r\n  box-shadow: var(--shadow-lg);\r\n  transition: transform var(--transition-base);\r\n}\r\n\r\n.carousel-img-container:hover {\r\n  transform: scale(1.02);\r\n}\r\n\r\n.carousel-overlay {\r\n  position: absolute;\r\n  bottom: 0;\r\n  left: 0;\r\n  right: 0;\r\n  background: linear-gradient(to top, rgba(0, 0, 0, 0.75), transparent);\r\n  padding: var(--spacing-2xl) var(--spacing-xl) var(--spacing-xl);\r\n  color: #fff;\r\n}\r\n\r\n.carousel-overlay h3 {\r\n  font-size: var(--font-size-2xl);\r\n  font-weight: var(--font-weight-semibold);\r\n  margin: 0 0 var(--spacing-sm) 0;\r\n  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);\r\n}\r\n\r\n.carousel-overlay p {\r\n  font-size: var(--font-size-sm);\r\n  margin: 0;\r\n  opacity: 0.95;\r\n  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);\r\n}\r\n\r\n.carousel-img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n:deep(.el-carousel__indicators) {\r\n  bottom: var(--spacing-lg);\r\n}\r\n\r\n:deep(.el-carousel__indicator) {\r\n  width: 8px;\r\n  height: 8px;\r\n  border-radius: var(--radius-full);\r\n  background-color: rgba(255, 255, 255, 0.5);\r\n  margin: 0 var(--spacing-xs);\r\n  transition: all var(--transition-base);\r\n}\r\n\r\n:deep(.el-carousel__indicator.is-active) {\r\n  background-color: var(--primary-color);\r\n  width: 28px;\r\n  border-radius: var(--radius-sm);\r\n}\r\n\r\n:deep(.el-carousel__arrow) {\r\n  background-color: rgba(255, 255, 255, 0.9);\r\n  border: none;\r\n  color: var(--primary-color);\r\n  font-size: var(--font-size-xl);\r\n  width: 44px;\r\n  height: 44px;\r\n  transition: all var(--transition-cubic);\r\n  box-shadow: var(--shadow-base);\r\n}\r\n\r\n:deep(.el-carousel__arrow:hover) {\r\n  background-color: #fff;\r\n  transform: scale(1.15);\r\n  box-shadow: var(--shadow-md);\r\n}\r\n\r\n/* 分类区域 */\r\n.category-section {\r\n  margin: var(--spacing-2xl) 0;\r\n  padding: var(--spacing-xl);\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: var(--shadow-base);\r\n  transition: all var(--transition-base);\r\n}\r\n\r\n.category-section:hover {\r\n  box-shadow: var(--shadow-md);\r\n}\r\n\r\n.section-header {\r\n  text-align: center;\r\n  margin-bottom: var(--spacing-xl);\r\n}\r\n\r\n.section-title {\r\n  font-size: var(--font-size-2xl);\r\n  font-weight: var(--font-weight-bold);\r\n  color: var(--text-primary);\r\n  margin: 0 0 var(--spacing-sm) 0;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: var(--spacing-sm);\r\n}\r\n\r\n.section-title i {\r\n  color: var(--primary-color);\r\n  font-size: var(--font-size-xl);\r\n}\r\n\r\n.section-desc {\r\n  font-size: var(--font-size-sm);\r\n  color: var(--text-tertiary);\r\n  margin: 0;\r\n}\r\n\r\n.category-buttons {\r\n  display: flex;\r\n  gap: var(--spacing-md);\r\n  flex-wrap: wrap;\r\n  justify-content: center;\r\n}\r\n\r\n.category-btn {\r\n  background: linear-gradient(135deg, var(--bg-tertiary) 0%, var(--bg-secondary) 100%);\r\n  border: 2px solid var(--border-light);\r\n  border-radius: var(--radius-md);\r\n  padding: var(--spacing-base) var(--spacing-xl);\r\n  font-size: var(--font-size-base);\r\n  font-weight: var(--font-weight-semibold);\r\n  color: var(--text-secondary);\r\n  transition: all var(--transition-cubic);\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--spacing-sm);\r\n  box-shadow: var(--shadow-sm);\r\n  cursor: pointer;\r\n}\r\n\r\n.category-btn:hover {\r\n  transform: translateY(-3px);\r\n  box-shadow: var(--shadow-primary);\r\n  border-color: var(--primary-color);\r\n  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);\r\n  color: var(--primary-color);\r\n}\r\n\r\n.category-btn.active {\r\n  background: var(--primary-gradient);\r\n  border-color: var(--primary-color);\r\n  color: #fff;\r\n  box-shadow: var(--shadow-primary);\r\n  transform: translateY(-3px);\r\n}\r\n\r\n.btn-icon {\r\n  font-size: var(--font-size-lg);\r\n}\r\n\r\n/* 推荐列表和分类列表 */\r\n.recommendation-list,\r\n.category-items {\r\n  margin-top: var(--spacing-2xl);\r\n  padding: 0 var(--spacing-lg);\r\n}\r\n\r\n.category-items {\r\n  background: var(--bg-primary);\r\n  padding