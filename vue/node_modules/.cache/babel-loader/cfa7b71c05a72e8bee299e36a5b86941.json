ype","description","rows","_component_el_date_picker","date","style","_component_el_select","area","_Fragment","_renderList","AREAS","item","_createBlock","_component_el_option","key","value","_toDisplayString","icon","_component_el_upload","action","$options","fileSuccessUpload","fileList","limit","handleExceed","_cache","videoSuccessUpload","videoList","accept","_component_el_button","_hoisted_3","onClick","cancel","size","save","loading","saving"],"sources":["C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\src\\views\\front\\LittleSaying.vue"],"sourcesContent":["<template>\r\n  <div class=\"post-container\">\r\n    <div class=\"post-card\">\r\n      <!-- 标题 -->\r\n      <div class=\"post-header\">\r\n        <h2 class=\"post-title\">\r\n          <i class=\"el-icon-edit-outline\"></i>\r\n          发布就业信息\r\n        </h2>\r\n        <p class=\"post-subtitle\">分享招聘资讯、求职经验，帮助更多同学</p>\r\n      </div>\r\n\r\n      <el-form :model=\"entity\" :rules=\"rules\" ref=\"entityForm\" label-width=\"100px\" class=\"post-form\">\r\n        <!-- 标题 -->\r\n        <el-form-item label=\"标题\" prop=\"name\">\r\n          <el-input\r\n            v-model=\"entity.name\"\r\n            placeholder=\"请输入信息标题（不超过 50 字）\"\r\n            maxlength=\"50\"\r\n            show-word-limit\r\n            clearable\r\n          />\r\n        </el-form-item>\r\n\r\n        <!-- 简介 -->\r\n        <el-form-item label=\"简介\" prop=\"description\">\r\n          <el-input\r\n            type=\"textarea\"\r\n            v-model=\"entity.description\"\r\n            placeholder=\"请简要描述该信息的主要内容...\"\r\n            :rows=\"4\"\r\n            maxlength=\"300\"\r\n            show-word-limit\r\n          />\r\n        </el-form-item>\r\n\r\n        <!-- 发布日期 -->\r\n        <el-form-item label=\"发布日期\" prop=\"date\">\r\n          <el-date-picker\r\n            v-model=\"entity.date\"\r\n            type=\"date\"\r\n            value-format=\"YYYY-MM-DD\"\r\n            placeholder=\"选择发布日期\"\r\n            style=\"width: 100%\"\r\n          />\r\n        </el-form-item>\r\n\r\n        <!-- 类型 -->\r\n        <el-form-item label=\"分类\" prop=\"area\">\r\n          <el-select\r\n            v-model=\"entity.area\"\r\n            placeholder=\"请选择信息分类\"\r\n            clearable\r\n            style=\"width: 100%\"\r\n          >\r\n            <el-option\r\n              v-for=\"item in AREAS\"\r\n              :key=\"item.key\"\r\n              :label=\"item.label\"\r\n              :value=\"item.key\"\r\n            >\r\n              <span>{{ item.icon }} {{ item.label }}</span>\r\n            </el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n\r\n        <!-- 图片上传 -->\r\n        <el-form-item label=\"封面图片\" prop=\"img\">\r\n          <el-upload\r\n            action=\"http://localhost:8080/files/upload\"\r\n            :on-success=\"fileSuccessUpload\"\r\n            :file-list=\"fileList\"\r\n            :limit=\"1\"\r\n            list-type=\"picture-card\"\r\n            :on-exceed=\"handleExceed\"\r\n          >\r\n            <i class=\"el-icon-plus\"></i>\r\n          </el-upload>\r\n          <div class=\"upload-tip\">建议尺寸：800×450px，支持 jpg/png，最大 5MB</div>\r\n        </el-form-item>\r\n\r\n        <!-- 视频上传（可选） -->\r\n        <el-form-item label=\"附件视频\">\r\n          <el-upload\r\n            action=\"http://localhost:8080/files/upload\"\r\n            :on-success=\"videoSuccessUpload\"\r\n            :file-list=\"videoList\"\r\n            :limit=\"1\"\r\n            accept=\"video/*\"\r\n            :on-exceed=\"handleExceed\"\r\n          >\r\n            <el-button type=\"default\" icon=\"el-icon-upload2\">上传视频（可选）</el-button>\r\n          </el-upload>\r\n        </el-form-item>\r\n\r\n        <!-- 按钮组 -->\r\n        <el-form-item>\r\n          <div class=\"form-actions\">\r\n            <el-button @click=\"cancel\" size=\"large\">取 消</el-button>\r\n            <el-button type=\"primary\" @click=\"save\" size=\"large\" :loading=\"saving\">\r\n              {{ saving ? '发布中...' : '立即发布' }}\r\n            </el-button>\r\n          </div>\r\n        </el-form-item>\r\n      </el-form>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from \"@/utils/request\";\r\n\r\nconst AREAS = [\r\n  { key: '校园招聘', label: '校园招聘', icon: '🏫' },\r\n  { key: '实习信息', label: '实习信息', icon: '💼' },\r\n  { key: '社会招聘', label: '社会招聘', icon: '🏢' },\r\n  { key: '求职技巧', label: '求职技巧', icon: '💡' },\r\n  { key: '行业动态', label: '行业动态', icon: '📊' },\r\n];\r\n\r\nexport default {\r\n  name: \"LittleSaying\",\r\n  data() {\r\n    return {\r\n      AREAS,\r\n      entity: {\r\n        name: \"\",\r\n        description: \"\",\r\n        date: \"\",\r\n        area: \"\",\r\n        img: \"\",\r\n        url: \"\"\r\n      },\r\n      fileList: [],\r\n      videoList: [],\r\n      saving: false,\r\n      rules: {\r\n        name: [\r\n          { required: true, message: \"请输入标题\", trigger: \"blur\" },\r\n          { max: 50, message: \"标题不能超过50字\", trigger: \"blur\" }\r\n        ],\r\n        description: [\r\n          { required: true, message: \"请输入简介\", trigger: \"blur\" }\r\n        ],\r\n        date: [{ required: true, message: \"请选择发布日期\", trigger: \"change\" }],\r\n        area: [{ required: true, message: \"请选择分类\", trigger: \"change\" }],\r\n        img: [{ required: true, message: \"请上传封面图片\", trigger: \"change\" }],\r\n      }\r\n    };\r\n  },\r\n  methods: {\r\n    fileSuccessUpload(res) {\r\n      if (res.code === '0') {\r\n        this.entity.img = res.data;\r\n        this.$message.success('图片上传成功');\r\n      }\r\n    },\r\n    videoSuccessUpload(res) {\r\n      if (res.code === '0') {\r\n        this.entity.url = res.data;\r\n        this.$message.success('视频上传成功');\r\n      }\r\n    },\r\n    handleExceed() {\r\n      this.$message.warning('最多上传 1 个文件，请先删除已上传的文件');\r\n    },\r\n    save() {\r\n      this.$refs.entityForm.validate(async (valid) => {\r\n        if (!valid) return;\r\n        this.saving = true;\r\n        try {\r\n          const res = await request.post(\"/movie\", this.entity);\r\n          if (res.code === '0') {\r\n            this.$message.success(\"发布成功！\");\r\n            this.$router.push('/front/home');\r\n          } else {\r\n            this.$message.error(res.msg || '发布失败');\r\n          }\r\n        } catch {\r\n          this.$message.error(\"网络错误，请稍后重试\");\r\n        } finally {\r\n          this.saving = false;\r\n        }\r\n      });\r\n    },\r\n    cancel() {\r\n      this.$router.back();\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.post-container {\r\n  max-width: 760px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.post-card {\r\n  background: var(--bg-primary);\r\n  border: 1px solid var(--border-lighter);\r\n  border-radius: var(--radius-xl);\r\n  padding: var(--spacing-2xl) var(--spacing-2xl);\r\n  box-shadow: var(--shadow-base);\r\n}\r\n\r\n.post-header {\r\n  margin-bottom: var(--spacing-2xl);\r\n  padding-bottom: var(--spacing-lg);\r\n  border-bottom: 2px solid var(--border-lighter);\r\n}\r\n\r\n.post-title {\r\n  font-size: var(--font-size-xl);\r\n  font-weight: var(--font-weight-bold);\r\n  color: var(--text-primary);\r\n  margin: 0 0 var(--spacing-sm);\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--spacing-sm);\r\n}\r\n\r\n.post-title i {\r\n  color: var(--primary-color);\r\n}\r\n\r\n.post-subtitle {\r\n  font-size: var(--font-size-sm);\r\n  color: var(--text-tertiary);\r\n  margin: 0;\r\n}\r\n\r\n.post-form :deep(.el-form-item__label) {\r\n  font-weight: var(--font-weight-semibold);\r\n  color: var(--text-secondary);\r\n}\r\n\r\n.post-form :deep(.el-upload--picture-card) {\r\n  border-radius: var(--radius-base);\r\n}\r\n\r\n.upload-tip {\r\n  font-size: var(--font-size-xs);\r\n  color: var(--text-disabled);\r\n  margin-top: var(--spacing-sm);\r\n}\r\n\r\n.form-actions {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  gap: var(--spacing-base);\r\n  padding-top: var(--spacing-md);\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .post-card {\r\n    padding: var(--spacing-lg) var(--spacing-md);\r\n  }\r\n}\r\n</style>\r\n"],"mappings":";;EACOA,KAAK,EAAC;AAAgB;;EACpBA,KAAK,EAAC;AAAW;;EA+FXA,KAAK,EAAC;AAAc;;;;;;;;;;uBAhGjCC,mBAAA,CAyGM,OAzGNC,UAyGM,GAxGJC,mBAAA,CAuGM,OAvGNC,UAuGM,G,0BArGJD,mBAAA,CAMM;IANDH,KAAK,EAAC;EAAa,IACtBG,mBAAA,CAGK;IAHDH,KAAK,EAAC;EAAY,IACpBG,mBAAA,CAAoC;IAAjCH,KAAK,EAAC;EAAsB,I,iBAAK,UAEtC,E,GACAG,mBAAA,CAA+C;IAA5CH,KAAK,EAAC;EAAe,GAAC,oBAAkB,E,QAG7CK,YAAA,CA4FUC,kBAAA;IA5FAC,KAAK,EAAEC,KAAA,CAAAC,MAAM;IAAGC,KAAK,EAAEF,KAAA,CAAAE,KAAK;IAAEC,GAAG,EAAC,YAAY;IAAC,aAAW,EAAC,OAAO;IAACX,KAAK,EAAC;;sBAEjF,MAQe,CARfK,YAAA,CAQeO,uBAAA;MARDC,KAAK,EAAC,IAAI;MAACC,IAAI,EAAC;;wBAC5B,MAME,CANFT,YAAA,CAMEU,mBAAA;oBALSP,KAAA,CAAAC,MAAM,CAACO,IAAI;mEAAXR,KAAA,CAAAC,MAAM,CAACO,IAAI,GAAAC,MAAA;QACpBC,WAAW,EAAC,mBAAmB;QAC/BC,SAAS,EAAC,IAAI;QACd,iBAAe,EAAf,EAAe;QACfC,SAAS,EAAT;;;QAKJf,YAAA,CASeO,uBAAA;MATDC,KAAK,EAAC,IAAI;MAACC,IAAI,EAAC;;wBAC5B,MAOE,CAPFT,YAAA,CAOEU,mBAAA;QANAM,IAAI,EAAC,UAAU;oBACNb,KAAA,CAAAC,MAAM,CAACa,WAAW;mEAAlBd,KAAA,CAAAC,MAAM,CAACa,WAAW,GAAAL,MAAA;QAC3BC,WAAW,EAAC,kBAAkB;QAC7BK,IAAI,EAAE,CAAC;QACRJ,SAAS,EAAC,KAAK;QACf,iBAAe,EAAf;;;QAKJd,YAAA,CAQeO,uBAAA;MARDC,KAAK,EAAC,MAAM;MAACC,IAAI,EAAC;;wBAC9B,MAME,CANFT,YAAA,CAMEmB,yBAAA;oBALShB,KAAA,CAAAC,MAAM,CAACgB,IAAI;mEAAXjB,KAAA,CAAAC,MAAM,CAACgB,IAAI,GAAAR,MAAA;QACpBI,IAAI,EAAC,MAAM;QACX,cAAY,EAAC,YAAY;QACzBH,WAAW,EAAC,QAAQ;QACpBQ,KAAmB,EAAnB;UAAA;QAAA;;;QAKJrB,YAAA,CAgBeO,uBAAA;MAhBDC,KAAK,EAAC,IAAI;MAACC,IAAI,EAAC;;wBAC5B,MAcY,CAdZT,YAAA,CAcYsB,oBAAA;oBAbDnB,KAAA,CAAAC,MAAM,CAACmB,IAAI;mEAAXpB,KAAA,CAAAC,MAAM,CAACmB,IAAI,GAAAX,MAAA;QACpBC,WAAW,EAAC,SAAS;QACrBE,SAAS,EAAT,EAAS;QACTM,KAAmB,EAAnB;UAAA;QAAA;;0BAGE,MAAqB,E,kBADvBzB,mBAAA,CAOY4B,SAAA,QAAAC,WAAA,CANKtB,KAAA,CAAAuB,KAAK,EAAbC,IAAI;+BADbC,YAAA,CAOYC,oBAAA;YALTC,GAAG,EAAEH,IAAI,CAACG,GAAG;YACbtB,KAAK,EAAEmB,IAAI,CAACnB,KAAK;YACjBuB,KAAK,EAAEJ,IAAI,CAACG;;8BAEb,MAA6C,CAA7ChC,mBAAA,CAA6C,cAAAkC,gBAAA,CAApCL,IAAI,CAACM,I