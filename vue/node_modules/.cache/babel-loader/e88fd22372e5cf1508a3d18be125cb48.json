l","width","align","default","_withCtx","scope","_normalizeClass","row","status","fixed","size","disabled","$event","publish","handleEdit","_component_el_popconfirm","title","onConfirm","handleDelete","id","reference","loading","length","_component_el_empty","description","_hoisted_4","_component_el_pagination","onSizeChange","handleSizeChange","onCurrentChange","handleCurrentChange","pageNum","pageSize","layout","total","_component_el_dialog","entity","dialogVisible","footer","save","_component_el_form","model","rules","ref","_component_el_form_item","_component_el_input","name","placeholder","clearable","content","rows"],"sources":["C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\src\\views\\notice.vue"],"sourcesContent":["<template>\r\n  <div class=\"admin-page\">\r\n    <div class=\"admin-toolbar\">\r\n      <el-button type=\"primary\" icon=\"el-icon-plus\" @click=\"add\">新增公告</el-button>\r\n    </div>\r\n\r\n    <div class=\"admin-table-wrap\">\r\n      <el-table v-loading=\"loading\" :data=\"tableData\" border stripe style=\"width: 100%\">\r\n        <el-table-column prop=\"name\"    label=\"公告名称\" min-width=\"160\" />\r\n        <el-table-column prop=\"content\" label=\"公告内容\" min-width=\"280\" show-overflow-tooltip />\r\n        <el-table-column prop=\"time\"    label=\"发布时间\" width=\"160\" />\r\n        <el-table-column label=\"状态\" width=\"100\" align=\"center\">\r\n          <template #default=\"scope\">\r\n            <span :class=\"['status-tag', scope.row.status === '已发布' ? 'published' : 'draft']\">\r\n              {{ scope.row.status || '草稿' }}\r\n            </span>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column label=\"操作\" width=\"200\" align=\"center\" fixed=\"right\">\r\n          <template #default=\"scope\">\r\n            <el-button\r\n              size=\"small\"\r\n              type=\"success\"\r\n              icon=\"el-icon-check\"\r\n              :disabled=\"scope.row.status === '已发布'\"\r\n              @click=\"publish(scope.row)\"\r\n            >\r\n              发布\r\n            </el-button>\r\n            <el-button size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\r\n            <el-popconfirm title=\"确定删除此公告吗？\" @confirm=\"handleDelete(scope.row.id)\">\r\n              <template #reference>\r\n                <el-button size=\"small\" type=\"danger\">删除</el-button>\r\n              </template>\r\n            </el-popconfirm>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n    </div>\r\n\r\n    <el-empty v-if=\"!loading && tableData.length === 0\" description=\"暂无公告\" />\r\n\r\n    <div class=\"admin-pagination\">\r\n      <el-pagination\r\n        @size-change=\"handleSizeChange\"\r\n        @current-change=\"handleCurrentChange\"\r\n        :current-page=\"pageNum\"\r\n        :page-sizes=\"[10, 20]\"\r\n        :page-size=\"pageSize\"\r\n        layout=\"total, sizes, prev, pager, next\"\r\n        :total=\"total\"\r\n      />\r\n    </div>\r\n\r\n    <!-- 弹框 -->\r\n    <el-dialog :title=\"entity.id ? '编辑公告' : '新增公告'\" v-model=\"dialogVisible\" width=\"500px\">\r\n      <el-form :model=\"entity\" :rules=\"rules\" ref=\"form\" label-width=\"80px\" class=\"dialog-form\">\r\n        <el-form-item label=\"名称\" prop=\"name\">\r\n          <el-input v-model=\"entity.name\" placeholder=\"请输入公告名称\" clearable />\r\n        </el-form-item>\r\n        <el-form-item label=\"内容\" prop=\"content\">\r\n          <el-input\r\n            type=\"textarea\"\r\n            v-model=\"entity.content\"\r\n            placeholder=\"请输入公告内容\"\r\n            :rows=\"4\"\r\n          />\r\n        </el-form-item>\r\n      </el-form>\r\n      <template #footer>\r\n        <el-button @click=\"dialogVisible = false\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"save\">确 定</el-button>\r\n      </template>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from \"@/utils/request\";\r\n\r\nexport default {\r\n  name: \"Notice\",\r\n  data() {\r\n    return {\r\n      loading: false,\r\n      entity: {},\r\n      dialogVisible: false,\r\n      pageNum: 1,\r\n      pageSize: 10,\r\n      total: 0,\r\n      tableData: [],\r\n      rules: {\r\n        name:    [{ required: true, message: \"请输入公告名称\", trigger: \"blur\" }],\r\n        content: [{ required: true, message: \"请输入公告内容\", trigger: \"blur\" }],\r\n      },\r\n    };\r\n  },\r\n  created() { this.load(); },\r\n  methods: {\r\n    load() {\r\n      this.loading = true;\r\n      request.get(\"/notice/page\", {\r\n        params: { pageNum: this.pageNum, pageSize: this.pageSize }\r\n      }).then(res => {\r\n        this.loading = false;\r\n        this.tableData = res.data.records;\r\n        this.total = res.data.total;\r\n      }).catch(() => { this.loading = false; });\r\n    },\r\n    add() { this.entity = {}; this.dialogVisible = true; },\r\n    save() {\r\n      this.$refs.form.validate(valid => {\r\n        if (!valid) return;\r\n        const method = this.entity.id ? \"put\" : \"post\";\r\n        request[method](\"/notice\", this.entity).then(res => {\r\n          if (res.code === '0') {\r\n            this.$message.success(this.entity.id ? '更新成功' : '新增成功');\r\n            this.load();\r\n            this.dialogVisible = false;\r\n          } else {\r\n            this.$message.error(res.msg);\r\n          }\r\n        });\r\n      });\r\n    },\r\n    handleEdit(row) { this.entity = { ...row }; this.dialogVisible = true; },\r\n    handleDelete(id) {\r\n      request.delete(\"/notice/\" + id).then(res => {\r\n        if (res.code === '0') { this.$message.success('删除成功'); this.load(); }\r\n        else this.$message.error(res.msg);\r\n      });\r\n    },\r\n    publish(row) {\r\n      row.status = \"已发布\";\r\n      request.put(\"/notice\", row).then(res => {\r\n        if (res.code === '0') this.$message.success('发布成功');\r\n        else this.$message.error(res.msg);\r\n      });\r\n    },\r\n    handleSizeChange(ps) { this.pageSize = ps; this.load(); },\r\n    handleCurrentChange(pn) { this.pageNum = pn; this.load(); },\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped></style>\r\n"],"mappings":";;EACOA,KAAK,EAAC;AAAY;;EAChBA,KAAK,EAAC;AAAe;;EAIrBA,KAAK,EAAC;AAAkB;;EAoCxBA,KAAK,EAAC;AAAkB;;;;;;;;;;;;;uBAzC/BC,mBAAA,CAyEM,OAzENC,UAyEM,GAxEJC,mBAAA,CAEM,OAFNC,UAEM,GADJC,YAAA,CAA2EC,oBAAA;IAAhEC,IAAI,EAAC,SAAS;IAACC,IAAI,EAAC,cAAc;IAAEC,OAAK,EAAEC,QAAA,CAAAC;;sBAAK,MAAIC,MAAA,QAAAA,MAAA,O,iBAAJ,MAAI,E;;wBAGjET,mBAAA,CAgCM,OAhCNU,UAgCM,G,+BA/BJC,YAAA,CA8BWC,mBAAA;IA9BoBC,IAAI,EAAEC,KAAA,CAAAC,SAAS;IAAEC,MAAM,EAAN,EAAM;IAACC,MAAM,EAAN,EAAM;IAACC,KAAmB,EAAnB;MAAA;IAAA;;sBAC5D,MAA+D,CAA/DhB,YAAA,CAA+DiB,0BAAA;MAA9CC,IAAI,EAAC,MAAM;MAAIC,KAAK,EAAC,MAAM;MAAC,WAAS,EAAC;QACvDnB,YAAA,CAAqFiB,0BAAA;MAApEC,IAAI,EAAC,SAAS;MAACC,KAAK,EAAC,MAAM;MAAC,WAAS,EAAC,KAAK;MAAC,uBAAqB,EAArB;QAC7DnB,YAAA,CAA2DiB,0BAAA;MAA1CC,IAAI,EAAC,MAAM;MAAIC,KAAK,EAAC,MAAM;MAACC,KAAK,EAAC;QACnDpB,YAAA,CAMkBiB,0BAAA;MANDE,KAAK,EAAC,IAAI;MAACC,KAAK,EAAC,KAAK;MAACC,KAAK,EAAC;;MACjCC,OAAO,EAAAC,QAAA,CAAEC,KAAK,KACvB1B,mBAAA,CAEO;QAFAH,KAAK,EAAA8B,eAAA,gBAAiBD,KAAK,CAACE,GAAG,CAACC,MAAM;0BACxCH,KAAK,CAACE,GAAG,CAACC,MAAM,c;;QAIzB3B,YAAA,CAkBkBiB,0BAAA;MAlBDE,KAAK,EAAC,IAAI;MAACC,KAAK,EAAC,KAAK;MAACC,KAAK,EAAC,QAAQ;MAACO,KAAK,EAAC;;MAChDN,OAAO,EAAAC,QAAA,CAAEC,KAAK,KACvBxB,YAAA,CAQYC,oBAAA;QAPV4B,IAAI,EAAC,OAAO;QACZ3B,IAAI,EAAC,SAAS;QACdC,IAAI,EAAC,eAAe;QACnB2B,QAAQ,EAAEN,KAAK,CAACE,GAAG,CAACC,MAAM;QAC1BvB,OAAK,EAAA2B,MAAA,IAAE1B,QAAA,CAAA2B,OAAO,CAACR,KAAK,CAACE,GAAG;;0BAC1B,MAEDnB,MAAA,QAAAA,MAAA,O,iBAFC,MAED,E;;yCACAP,YAAA,CAAqEC,oBAAA;QAA1D4B,IAAI,EAAC,OAAO;QAAEzB,OAAK,EAAA2B,MAAA,IAAE1B,QAAA,CAAA4B,UAAU,CAACT,KAAK,CAACE,GAAG;;0BAAG,MAAEnB,MAAA,QAAAA,MAAA,O,iBAAF,IAAE,E;;6BACzDP,YAAA,CAIgBkC,wBAAA;QAJDC,KAAK,EAAC,WAAW;QAAEC,SAAO,EAAAL,MAAA,IAAE1B,QAAA,CAAAgC,YAAY,CAACb,KAAK,CAACE,GAAG,CAACY,EAAE;;QACvDC,SAAS,EAAAhB,QAAA,CAClB,MAAoD,CAApDvB,YAAA,CAAoDC,oBAAA;UAAzC4B,IAAI,EAAC,OAAO;UAAC3B,IAAI,EAA