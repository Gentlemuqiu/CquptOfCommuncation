 <el-button type=\"primary\" icon=\"el-icon-plus\" @click=\"add\">新增信息</el-button>\r\n      <el-input\r\n        v-model=\"search\"\r\n        placeholder=\"搜索标题/简介...\"\r\n        clearable\r\n        class=\"search-input\"\r\n        @keyup.enter=\"load\"\r\n      >\r\n        <template #append>\r\n          <el-button icon=\"el-icon-search\" @click=\"load\" />\r\n        </template>\r\n      </el-input>\r\n    </div>\r\n\r\n    <!-- 数据表格 -->\r\n    <div class=\"admin-table-wrap\">\r\n      <el-table\r\n        v-loading=\"loading\"\r\n        :data=\"tableData\"\r\n        border\r\n        stripe\r\n        style=\"width: 100%\"\r\n      >\r\n        <el-table-column prop=\"name\" label=\"标题\" min-width=\"160\" show-overflow-tooltip />\r\n        <el-table-column prop=\"description\" label=\"简介\" min-width=\"200\" show-overflow-tooltip />\r\n        <el-table-column prop=\"date\" label=\"发布日期\" width=\"120\" />\r\n        <el-table-column prop=\"area\" label=\"分类\" width=\"110\">\r\n          <template #default=\"scope\">\r\n            <el-tag size=\"small\" type=\"success\" effect=\"plain\">{{ scope.row.area }}</el-tag>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column label=\"赞/踩\" width=\"100\" align=\"center\">\r\n          <template #default=\"scope\">\r\n            <span style=\"color: var(--success-color)\">{{ scope.row.zan || 0 }}</span>\r\n            /\r\n            <span style=\"color: var(--danger-color)\">{{ scope.row.cai || 0 }}</span>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column label=\"封面\" width=\"90\" align=\"center\">\r\n          <template #default=\"scope\">\r\n            <el-image\r\n              style=\"width: 60px; height: 60px; border-radius: 6px\"\r\n              :src=\"scope.row.img\"\r\n              fit=\"cover\"\r\n              :preview-src-list=\"[scope.row.img]\"\r\n            />\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column label=\"操作\" width=\"140\" align=\"center\" fixed=\"right\">\r\n          <template #default=\"scope\">\r\n            <el-button size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\r\n            <el-popconfirm title=\"确定删除此条信息吗？\" @confirm=\"handleDelete(scope.row.id)\">\r\n              <template #reference>\r\n                <el-button size=\"small\" type=\"danger\">删除</el-button>\r\n              </template>\r\n            </el-popconfirm>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n    </div>\r\n\r\n    <el-empty v-if=\"!loading && tableData.length === 0\" description=\"暂无数据\" />\r\n\r\n    <!-- 分页 -->\r\n    <div class=\"admin-pagination\">\r\n      <el-pagination\r\n        @size-change=\"handleSizeChange\"\r\n        @current-change=\"handleCurrentChange\"\r\n        :current-page=\"pageNum\"\r\n        :page-sizes=\"[10, 20, 50]\"\r\n        :page-size=\"pageSize\"\r\n        layout=\"total, sizes, prev, pager, next\"\r\n        :total=\"total\"\r\n      />\r\n    </div>\r\n\r\n    <!-- 编辑弹框 -->\r\n    <el-dialog :title=\"entity.id ? '编辑信息' : '新增信息'\" v-model=\"dialogVisible\" width=\"560px\">\r\n      <el-form :model=\"entity\" :rules=\"rules\" ref=\"entityForm\" label-width=\"90px\" class=\"dialog-form\">\r\n        <el-form-item label=\"标题\" prop=\"name\">\r\n          <el-input v-model=\"entity.name\" placeholder=\"请输入标题\" clearable />\r\n        </el-form-item>\r\n        <el-form-item label=\"简介\" prop=\"description\">\r\n          <el-input\r\n            type=\"textarea\"\r\n            v-model=\"entity.description\"\r\n            placeholder=\"请输入简介\"\r\n            :rows=\"3\"\r\n          />\r\n        </el-form-item>\r\n        <el-form-item label=\"发布日期\" prop=\"date\">\r\n          <el-date-picker\r\n            style=\"width: 100%\"\r\n            v-model=\"entity.date\"\r\n            type=\"date\"\r\n            value-format=\"YYYY-MM-DD\"\r\n            placeholder=\"选择日期\"\r\n          />\r\n        </el-form-item>\r\n        <el-form-item label=\"分类\" prop=\"area\">\r\n          <el-select v-model=\"entity.area\" placeholder=\"请选择分类\" clearable style=\"width: 100%\">\r\n            <el-option\r\n              v-for=\"item in AREAS\"\r\n              :key=\"item\"\r\n              :label=\"item\"\r\n              :value=\"item\"\r\n            />\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"封面图片\">\r\n          <el-upload\r\n            action=\"http://localhost:8080/files/upload\"\r\n            :on-success=\"fileSuccessUpload\"\r\n            :file-list=\"fileList\"\r\n            :limit=\"1\"\r\n            list-type=\"picture\"\r\n          >\r\n            <el-button type=\"default\" icon=\"el-icon-upload2\">上传图片</el-button>\r\n          </el-upload>\r\n        </el-form-item>\r\n        <el-form-item label=\"视频\">\r\n          <el-upload\r\n            action=\"http://localhost:8080/files/upload\"\r\n            :on-success=\"videoSuccessUpload\"\r\n            :file-list=\"videoList\"\r\n            :limit=\"1\"\r\n            accept=\"video/*\"\r\n          >\r\n            <el-button type=\"default\" icon=\"el-icon-upload2\">上传视频</el-button>\r\n          </el-upload>\r\n        </el-form-item>\r\n      </el-form>\r\n      <template #footer>\r\n        <el-button @click=\"dialogVisible = false\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"save\">保 存</el-button>\r\n      </template>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from \"@/utils/request\";\r\nimport { INFO_AREAS } from \"@/config/navigation\";\r\n\r\nconst URL = \"/movie\";\r\n\r\nexport default {\r\n  name: \"Sayings\",\r\n  data() {\r\n    return {\r\n      AREAS: INFO_AREAS.map(a => a.key),\r\n      loading: false,\r\n      entity: {},\r\n      dialogVisible: false,\r\n      search: \"\",\r\n      pageNum: 1,\r\n      pageSize: 10,\r\n      total: 0,\r\n      tableData: [],\r\n      fileList: [],\r\n      videoList: [],\r\n      rules: {\r\n        name:        [{ required: true, message: \"请输入标题\", trigger: \"blur\" }],\r\n        description: [{ required: true, message: \"请输入简介\", trigger: \"blur\" }],\r\n        date:        [{ required: true, message: \"请选择发布日期\", trigger: \"change\" }],\r\n        area:        [{ required: true, message: \"请选择分类\", trigger: \"change\" }],\r\n      }\r\n    };\r\n  },\r\n  created() { this.load(); },\r\n  methods: {\r\n    load() {\r\n      this.loading = true;\r\n      request.get(URL + \"/page\", {\r\n        params: { pageNum: this.pageNum, pageSize: this.pageSize, search: this.search }\r\n      }).then(res => {\r\n        this.loading = false;\r\n        this.tableData = res.data.records;\r\n        this.total = res.data.total;\r\n      }).catch(() => { this.loading = false; });\r\n    },\r\n    add() {\r\n      this.entity = { name: \"\", description: \"\", date: \"\", area: \"\", img: \"\", url: \"\" };\r\n      this.fileList = [];\r\n      this.videoList = [];\r\n      this.dialogVisible = true;\r\n    },\r\n    save() {\r\n      this.$refs.entityForm.validate(valid => {\r\n        if (!valid) return;\r\n        const method = this.entity.id ? \"put\" : \"post\";\r\n        request[method](URL, this.entity).then(res => {\r\n          if (res.code === '0') {\r\n            this.$message.success(this.entity.id ? '更新成功' : '新增成功');\r\n            this.load();\r\n            this.dialogVisible = false;\r\n          } else {\r\n            this.$message.error(res.msg);\r\n          }\r\n        });\r\n      });\r\n    },\r\n    handleEdit(row) {\r\n      this.entity = { ...row };\r\n      this.fileList = [];\r\n      this.videoList = [];\r\n      this.dialogVisible = true;\r\n    },\r\n    handleDelete(id) {\r\n      request.delete(URL + \"/\" + id).then(() => {\r\n        this.$message.success('删除成功');\r\n        this.load();\r\n      });\r\n    },\r\n    fileSuccessUpload(res) { this.entity.img = res.data; },\r\n    videoSuccessUpload(res) { this.entity.url = res.data; },\r\n    handleSizeChange(pageSize) { this.pageSize = pageSize; this.load(); },\r\n    handleCurrentChange(pageNum) { this.pageNum = pageNum; this.load(); },\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped></style>\r\n"],"mappings":";AAiJA,OAAOA,OAAM,MAAO,iBAAiB;AACrC,SAASC,UAAS,QAAS,qBAAqB;AAEhD,MAAMC,GAAE,GAAI,QAAQ;AAEpB,eAAe;EACbC,IAAI,EAAE,SAAS;EACfC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAEJ,UAAU,CAACK,GAAG,CAACC,CAAA,IAAKA,CAAC,CAACC,GAAG,CAAC;MACjCC,OAAO,EAAE,KAAK;MACdC,MAAM,EAAE,CAAC,CAAC;MACVC,aAAa,EAAE,KAAK;MACpBC,MAAM,EAAE,EAAE;MACVC,OAAO,EAAE,CAAC;MACVC,QAAQ,EAAE,EAAE;MACZC,KAAK,EAAE,CAAC;MACRC,SAAS,EAAE,EAAE;MACbC,QAAQ,EAAE,EAAE;MACZC,SAAS,EAAE,EAAE;MACbC,KAAK,EAAE;QACLhB,IAAI,EAAS,CAAC;UAAEiB,QAAQ,EAAE,IAAI;UAAEC,OAAO,EAAE,OAAO;UAAEC,OAAO,EAAE;QAAO,CAAC,CAAC;QACpEC,WAAW,EAAE,CAAC;UAAEH,QAAQ,EAAE,IAAI;UAAEC,OAAO,EAAE,OAAO;UAAEC,OAAO,EAAE;QAAO,CAAC,CAAC;QACpEE,IAAI,EAAS,CAAC;UAAEJ,QAAQ,EAAE,IAAI;UAAEC,OAAO,EAAE,SAAS;UAAEC,OAAO,EAAE;QAAS,CAAC,CAAC;QACxEG,IAAI,EAAS,CAAC;UAAEL,QAAQ,EAAE,IAAI;UAAEC,OAAO,EAAE,OAAO;UAAEC,OAAO,EAAE;QAAS,CAAC;MACvE;IACF,CAAC;EACH,CAAC;EACDI,OAAOA,CAAA,EAAG;IAAE,IAAI,CAACC,IAAI,CAAC,CAAC;EAAE,CAAC;EAC1BC,OAAO,EAAE;IACPD,IAAIA,CAAA,EAAG;MACL,IAAI,CAAClB,OAAM,GAAI,IAAI;MACnBT,OAAO,CAAC6B,GAAG,CAAC3B,GAAE,GAAI,OAAO,EAAE;QACzB4B,MAAM,EAAE;UAAEjB,OAAO,EAAE,IAAI,CAACA,OAAO;UAAEC,QAAQ,EAAE,IAAI,CAACA,QAAQ;UAAEF,MAAM,EAAE,IAAI,CAACA;QAAO;MAChF,CAAC,CAAC,CAACmB,IAAI,CAACC,GAAE,IAAK;QACb,IAAI,CAACvB,OAAM,GAAI,KAAK;QACpB,IAAI,CAACO,SAAQ,GAAIgB,GAAG,CAAC5B,IAAI,CAAC6B,OAAO;QACjC,IAAI,CAAClB,KAAI,GAAIiB,GAAG,CAAC5B,IAAI,CAACW,KAAK;MAC7B,CAAC,CAAC,CAACmB,KAAK,CAAC,MAAM;QAAE,IAAI,CAACzB,OAAM,GAAI,KAAK;MAAE,CAAC,CAAC;IAC3C,CAAC;IACD0B,GAAGA,CAAA,EAAG;MACJ,IAAI,CAACzB,MAAK,GAAI;QAAEP,IAAI,EAAE,EAAE;QAAEoB,WAAW,EAAE,EAAE;QAAEC,IAAI,EAAE,EAAE;QAAEC,IAAI,EAAE,EAAE;QAAEW,GAAG,EAAE,EAAE;QAAEC,GAAG,EAAE;MAAG,CAAC;MACjF,IAAI,CAACpB,QAAO,GAAI,EAAE;MAClB,IAAI,CAACC,SAAQ,GAAI,EAAE;