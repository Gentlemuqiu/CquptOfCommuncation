   <div class=\"logo-wrap\">\r\n            <img src=\"../assets/image/cqupt.svg\" alt=\"Logo\" class=\"auth-logo\">\r\n          </div>\r\n          <h1 class=\"auth-title\">欢迎登录</h1>\r\n          <p class=\"auth-subtitle\">就业信息中心 · 助力职业发展</p>\r\n        </div>\r\n\r\n        <el-form\r\n          ref=\"form\"\r\n          :model=\"form\"\r\n          size=\"large\"\r\n          :rules=\"rules\"\r\n          class=\"auth-form\"\r\n        >\r\n          <el-form-item prop=\"username\">\r\n            <el-input\r\n              v-model=\"form.username\"\r\n              placeholder=\"请输入用户名\"\r\n              class=\"auth-input\"\r\n              clearable\r\n            >\r\n              <template #prefix><el-icon><User /></el-icon></template>\r\n            </el-input>\r\n          </el-form-item>\r\n\r\n          <el-form-item prop=\"password\">\r\n            <el-input\r\n              v-model=\"form.password\"\r\n              placeholder=\"请输入密码\"\r\n              show-password\r\n              class=\"auth-input\"\r\n              @keyup.enter=\"login\"\r\n            >\r\n              <template #prefix><el-icon><Lock /></el-icon></template>\r\n            </el-input>\r\n          </el-form-item>\r\n\r\n          <el-form-item>\r\n            <el-button\r\n              :loading=\"loading\"\r\n              class=\"auth-submit-btn\"\r\n              type=\"primary\"\r\n              @click=\"login\"\r\n              size=\"large\"\r\n            >\r\n              <span v-if=\"!loading\">登 录</span>\r\n              <span v-else>登录中...</span>\r\n            </el-button>\r\n          </el-form-item>\r\n        </el-form>\r\n\r\n        <div class=\"auth-footer\">\r\n          <el-link type=\"primary\" @click=\"$router.push('/pass')\" :underline=\"false\" class=\"footer-link\">\r\n            忘记密码？\r\n          </el-link>\r\n          <span class=\"footer-divider\">|</span>\r\n          <el-link type=\"primary\" @click=\"$router.push('/register')\" :underline=\"false\" class=\"footer-link\">\r\n            立即注册 →\r\n          </el-link>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { login } from '@/api/user'\r\nimport { clearUser, setUser } from '@/utils/auth'\r\nimport { User, Lock } from '@element-plus/icons-vue'\r\n\r\nexport default {\r\n  name: 'Login',\r\n  components: { User, Lock },\r\n  data() {\r\n    return {\r\n      form: { username: '', password: '' },\r\n      loading: false,\r\n      rules: {\r\n        username: [{ required: true, message: '请输入用户名', trigger: 'blur' }],\r\n        password: [{ required: true, message: '请输入密码', trigger: 'blur' }],\r\n      },\r\n    }\r\n  },\r\n  created() {\r\n    clearUser()\r\n  },\r\n  methods: {\r\n    login() {\r\n      this.$refs.form.validate(async valid => {\r\n        if (!valid) return\r\n        this.loading = true\r\n        try {\r\n          const res = await login(this.form)\r\n          if (res.code === '0') {\r\n            this.$message.success('登录成功')\r\n            setUser(res.data)\r\n            this.$router.push(res.data.role !== 1 ? '/front/home' : '/')\r\n          } else {\r\n            this.$message.error(res.msg)\r\n          }\r\n        } catch {\r\n          this.$message.error('网络错误，请稍后再试')\r\n        } finally {\r\n          this.loading = false\r\n        }\r\n      })\r\n    },\r\n  },\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* ── 背景装饰球（Login 专属位置） ── */\r\n.bg-orb-1 {\r\n  width: 500px; height: 500px;\r\n  background: radial-gradient(circle, var(--primary-lighter) 0%, transparent 70%);\r\n  top: -150px; right: -100px;\r\n  animation: float-orb 22s ease-in-out infinite;\r\n}\r\n.bg-orb-2 {\r\n  width: 400px; height: 400px;\r\n  background: radial-gradient(circle, #3b82f6 0%, transparent 70%);\r\n  bottom: -100px; left: -100px;\r\n  animation: float-orb 28s ease-in-out infinite reverse;\r\n}\r\n.bg-orb-3 {\r\n  width: 250px; height: 250px;\r\n  background: radial-gradient(circle, #8b5cf6 0%, transparent 70%);\r\n  top: 40%; right: 30%;\r\n  animation: float-orb 16s ease-in-out infinite 3s;\r\n}\r\n</style>\r\n"],"mappings":";AA+EA,SAASA,KAAI,QAAS,YAAW;AACjC,SAASC,SAAS,EAAEC,OAAM,QAAS,cAAa;AAChD,SAASC,IAAI,EAAEC,IAAG,QAAS,yBAAwB;AAEnD,eAAe;EACbC,IAAI,EAAE,OAAO;EACbC,UAAU,EAAE;IAAEH,IAAI;IAAEC;EAAK,CAAC;EAC1BG,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAE;QAAEC,QAAQ,EAAE,EAAE;QAAEC,QAAQ,EAAE;MAAG,CAAC;MACpCC,OAAO,EAAE,KAAK;MACdC,KAAK,EAAE;QACLH,QAAQ,EAAE,CAAC;UAAEI,QAAQ,EAAE,IAAI;UAAEC,OAAO,EAAE,QAAQ;UAAEC,OAAO,EAAE;QAAO,CAAC,CAAC;QAClEL,QAAQ,EAAE,CAAC;UAAEG,QAAQ,EAAE,IAAI;UAAEC,OAAO,EAAE,OAAO;UAAEC,OAAO,EAAE;QAAO,CAAC;MAClE;IACF;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACRf,SAAS,CAAC;EACZ,CAAC;EACDgB,OAAO,EAAE;IACPjB,KAAKA,CAAA,EAAG;MACN,IAAI,CAACkB,KAAK,CAACV,IAAI,CAACW,QAAQ,CAAC,MAAMC,KAAI,IAAK;QACtC,IAAI,CAACA,KAAK,EAAE;QACZ,IAAI,CAACT,OAAM,GAAI,IAAG;QAClB,IAAI;UACF,MAAMU,GAAE,GAAI,MAAMrB,KAAK,CAAC,IAAI,CAACQ,IAAI;UACjC,IAAIa,GAAG,CAACC,IAAG,KAAM,GAAG,EAAE;YACpB,IAAI,CAACC,QAAQ,CAACC,OAAO,CAAC,MAAM;YAC5BtB,OAAO,CAACmB,GAAG,CAACd,IAAI;YAChB,IAAI,CAACkB,OAAO,CAACC,IAAI,CAACL,GAAG,CAACd,IAAI,CAACoB,IAAG,KAAM,IAAI,aAAY,GAAI,GAAG;UAC7D,OAAO;YACL,IAAI,CAACJ,QAAQ,CAACK,KAAK,CAACP,GAAG,CAACQ,GAAG;UAC7B;QACF,EAAE,MAAM;UACN,IAAI,CAACN,QAAQ,CAACK,KAAK,CAAC,YAAY;QAClC,UAAU;UACR,IAAI,CAACjB,OAAM,GAAI,KAAI;QACrB;MACF,CAAC;IACH;EACF;AACF","ignoreList":[]}]}