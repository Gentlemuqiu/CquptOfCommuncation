oisted_6","_component_el_link","_cache","_ctx","$router","push","underline"],"sources":["C:\\Code\\VueProjects\\CquptOfCommuncation\\vue\\src\\views\\Login.vue"],"sourcesContent":["<template>\r\n  <div class=\"auth-page\">\r\n    <!-- 背景装饰 -->\r\n    <div class=\"bg-decoration\">\r\n      <div class=\"bg-orb bg-orb-1\"></div>\r\n      <div class=\"bg-orb bg-orb-2\"></div>\r\n      <div class=\"bg-orb bg-orb-3\"></div>\r\n    </div>\r\n\r\n    <div class=\"auth-wrapper\">\r\n      <div class=\"auth-card\">\r\n        <!-- 顶部 Logo -->\r\n        <div class=\"auth-header\">\r\n          <div class=\"logo-wrap\">\r\n            <img src=\"../assets/image/cqupt.svg\" alt=\"Logo\" class=\"auth-logo\">\r\n          </div>\r\n          <h1 class=\"auth-title\">欢迎登录</h1>\r\n          <p class=\"auth-subtitle\">就业信息中心 · 助力职业发展</p>\r\n        </div>\r\n\r\n        <el-form\r\n          ref=\"form\"\r\n          :model=\"form\"\r\n          size=\"large\"\r\n          :rules=\"rules\"\r\n          class=\"auth-form\"\r\n        >\r\n          <el-form-item prop=\"username\">\r\n            <el-input\r\n              v-model=\"form.username\"\r\n              placeholder=\"请输入用户名\"\r\n              class=\"auth-input\"\r\n              clearable\r\n            >\r\n              <template #prefix><el-icon><User /></el-icon></template>\r\n            </el-input>\r\n          </el-form-item>\r\n\r\n          <el-form-item prop=\"password\">\r\n            <el-input\r\n              v-model=\"form.password\"\r\n              placeholder=\"请输入密码\"\r\n              show-password\r\n              class=\"auth-input\"\r\n              @keyup.enter=\"login\"\r\n            >\r\n              <template #prefix><el-icon><Lock /></el-icon></template>\r\n            </el-input>\r\n          </el-form-item>\r\n\r\n          <el-form-item>\r\n            <el-button\r\n              :loading=\"loading\"\r\n              class=\"auth-submit-btn\"\r\n              type=\"primary\"\r\n              @click=\"login\"\r\n              size=\"large\"\r\n            >\r\n              <span v-if=\"!loading\">登 录</span>\r\n              <span v-else>登录中...</span>\r\n            </el-button>\r\n          </el-form-item>\r\n        </el-form>\r\n\r\n        <div class=\"auth-footer\">\r\n          <el-link type=\"primary\" @click=\"$router.push('/pass')\" :underline=\"false\" class=\"footer-link\">\r\n            忘记密码？\r\n          </el-link>\r\n          <span class=\"footer-divider\">|</span>\r\n          <el-link type=\"primary\" @click=\"$router.push('/register')\" :underline=\"false\" class=\"footer-link\">\r\n            立即注册 →\r\n          </el-link>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { login } from '@/api/user'\r\nimport { clearUser, setUser } from '@/utils/auth'\r\nimport { User, Lock } from '@element-plus/icons-vue'\r\n\r\nexport default {\r\n  name: 'Login',\r\n  components: { User, Lock },\r\n  data() {\r\n    return {\r\n      form: { username: '', password: '' },\r\n      loading: false,\r\n      rules: {\r\n        username: [{ required: true, message: '请输入用户名', trigger: 'blur' }],\r\n        password: [{ required: true, message: '请输入密码', trigger: 'blur' }],\r\n      },\r\n    }\r\n  },\r\n  created() {\r\n    clearUser()\r\n  },\r\n  methods: {\r\n    login() {\r\n      this.$refs.form.validate(async valid => {\r\n        if (!valid) return\r\n        this.loading = true\r\n        try {\r\n          const res = await login(this.form)\r\n          if (res.code === '0') {\r\n            this.$message.success('登录成功')\r\n            setUser(res.data)\r\n            this.$router.push(res.data.role !== 1 ? '/front/home' : '/')\r\n          } else {\r\n            this.$message.error(res.msg)\r\n          }\r\n        } catch {\r\n          this.$message.error('网络错误，请稍后再试')\r\n        } finally {\r\n          this.loading = false\r\n        }\r\n      })\r\n    },\r\n  },\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* ── 背景装饰球（Login 专属位置） ── */\r\n.bg-orb-1 {\r\n  width: 500px; height: 500px;\r\n  background: radial-gradient(circle, var(--primary-lighter) 0%, transparent 70%);\r\n  top: -150px; right: -100px;\r\n  animation: float-orb 22s ease-in-out infinite;\r\n}\r\n.bg-orb-2 {\r\n  width: 400px; height: 400px;\r\n  background: radial-gradient(circle, #3b82f6 0%, transparent 70%);\r\n  bottom: -100px; left: -100px;\r\n  animation: float-orb 28s ease-in-out infinite reverse;\r\n}\r\n.bg-orb-3 {\r\n  width: 250px; height: 250px;\r\n  background: radial-gradient(circle, #8b5cf6 0%, transparent 70%);\r\n  top: 40%; right: 30%;\r\n  animation: float-orb 16s ease-in-out infinite 3s;\r\n}\r\n</style>\r\n"],"mappings":";;OAciBA,UAA+B;;EAbzCC,KAAK,EAAC;AAAW;;EAQfA,KAAK,EAAC;AAAc;;EAClBA,KAAK,EAAC;AAAW;;;;;;;;EAsDfA,KAAK,EAAC;AAAa;;;;;;;;;;uBA/D9BC,mBAAA,CA0EM,OA1ENC,UA0EM,GAzEJC,mBAAA,UAAa,E,0BACbC,mBAAA,CAIM;IAJDJ,KAAK,EAAC;EAAe,IACxBI,mBAAA,CAAmC;IAA9BJ,KAAK,EAAC;EAAiB,IAC5BI,mBAAA,CAAmC;IAA9BJ,KAAK,EAAC;EAAiB,IAC5BI,mBAAA,CAAmC;IAA9BJ,KAAK,EAAC;EAAiB,G,sBAG9BI,mBAAA,CAiEM,OAjENC,UAiEM,GAhEJD,mBAAA,CA+DM,OA/DNE,UA+DM,GA9DJH,mBAAA,aAAgB,E,uVAShBI,YAAA,CA0CUC,kBAAA;IAzCRC,GAAG,EAAC,MAAM;IACTC,KAAK,EAAEC,KAAA,CAAAC,IAAI;IACZC,IAAI,EAAC,OAAO;IACXC,KAAK,EAAEH,KAAA,CAAAG,KAAK;IACbd,KAAK,EAAC;;sBAEN,MASe,CATfO,YAAA,CASeQ,uBAAA;MATDC,IAAI,EAAC;IAAU;wBAC3B,MAOW,CAPXT,YAAA,CAOWU,mBAAA;oBANAN,KAAA,CAAAC,IAAI,CAACM,QAAQ;mEAAbP,KAAA,CAAAC,IAAI,CAACM,QAAQ,GAAAC,MAAA;QACtBC,WAAW,EAAC,QAAQ;QACpBpB,KAAK,EAAC,YAAY;QAClBqB,SAAS,EAAT;;QAEWC,MAAM,EAAAC,QAAA,CAAC,MAA2B,CAA3BhB,YAAA,CAA2BiB,kBAAA;4BAAlB,MAAQ,CAARjB,YAAA,CAAQkB,eAAA,E;;;;;;QAIvClB,YAAA,CAUeQ,uBAAA;MAVDC,IAAI,EAAC;IAAU;wBAC3B,MAQW,CARXT,YAAA,CAQWU,mBAAA;oBAPAN,KAAA,CAAAC,IAAI,CAACc,QAAQ;mEAAbf,KAAA,CAAAC,IAAI,CAACc,QAAQ,GAAAP,MAAA;QACtBC,WAAW,EAAC,OAAO;QACnB,eAAa,EAAb,EAAa;QACbpB,KAAK,EAAC,YAAY;QACjB2B,OAAK,EAAAC,SAAA,CAAQC,QAAA,CAAAC,KAAK;;QAERR,MAAM,EAAAC,QAAA,CAAC,MAA2B,CAA3BhB,YAAA,CAA2BiB,kBAAA;4BAAlB,MAAQ,CAA