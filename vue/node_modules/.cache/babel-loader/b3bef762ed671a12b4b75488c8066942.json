 :default-active=\"path\" router class=\"aside-menu\">\r\n      <el-submenu index=\"system\" v-if=\"systemItems.length\">\r\n        <template #title>\r\n          <span>系统管理</span>\r\n        </template>\r\n        <el-menu-item v-for=\"item in systemItems\" :key=\"item.path\" :index=\"item.path\">\r\n          <i :class=\"item.icon\"></i>\r\n          <span>{{ item.label }}</span>\r\n        </el-menu-item>\r\n      </el-submenu>\r\n\r\n      <el-menu-item v-for=\"item in normalItems\" :key=\"item.path\" :index=\"item.path\">\r\n        <i :class=\"item.icon\"></i>\r\n        <span>{{ item.label }}</span>\r\n      </el-menu-item>\r\n    </el-menu>\r\n  </aside>\r\n</template>\r\n\r\n<script>\r\nimport request from \"@/utils/request\";\r\nimport { ADMIN_SIDEBAR_ITEMS } from \"@/config/navigation\";\r\n\r\nexport default {\r\n  name: \"Aside\",\r\n  data() {\r\n    return {\r\n      user: {},\r\n      path: this.$route.path   // 设置默认高亮的菜单\r\n    }\r\n  },\r\n  computed: {\r\n    filteredItems() {\r\n      return ADMIN_SIDEBAR_ITEMS.filter(item => {\r\n        if (!item.requireRole) return true;\r\n        return item.requireRole === this.user.role;\r\n      });\r\n    },\r\n    systemItems() {\r\n      return this.filteredItems.filter(item => item.group === '系统管理');\r\n    },\r\n    normalItems() {\r\n      return this.filteredItems.filter(item => item.group !== '系统管理');\r\n    }\r\n  },\r\n  created() {\r\n    let userStr = sessionStorage.getItem(\"user\") || \"{}\"\r\n    this.user = JSON.parse(userStr)\r\n\r\n    // 请求服务端，确认当前登录用户的 合法信息\r\n    if (this.user.id) {\r\n      request.get(\"/user/\" + this.user.id).then(res => {\r\n        if (res.code === '0') {\r\n          this.user = res.data\r\n        }\r\n      })\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.admin-aside {\r\n  width: 220px;\r\n  flex-shrink: 0;\r\n  background: var(--bg-primary);\r\n  border: 1px solid var(--border-light);\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: va