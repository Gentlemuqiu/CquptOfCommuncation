{\r\n      request.get(`/collect/user/${this.user.id}`).then((res) => {\r\n        if (res.code === \"0\") {\r\n          this.tableData = res.data; // 加载表格数据\r\n        } else {\r\n          this.$message.error(res.msg || \"加载失败\");\r\n        }\r\n      });\r\n    },\r\n    // 显示长评论内容\r\n    show(content) {\r\n      this.longComment = content;\r\n      this.vis = true;\r\n    },\r\n    // 删除收藏\r\n    handleDelete(id) {\r\n      request\r\n        .delete(`/collect/${id}`) // 调用后端的删除接口\r\n        .then((res) => {\r\n          if (res.code === \"0\") {\r\n            this.$message({\r\n              type: \"success\",\r\n              message: \"取消收藏成功\",\r\n            });\r\n            this.load(); // 刷新表格数据\r\n          } else {\r\n            this.$message.error(res.msg || \"取消收藏失败\");\r\n          }\r\n        })\r\n        .catch(() => {\r\n          this.$message.error(\"取消收藏失败，请稍后重试\");\r\n        });\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.el-table {\r\n  margin-top: 10px;\r\n}\r\n</style>\r\n"],"mappings":";;EACOA,KAAqB,EAArB;IAAA;EAAA;AAAqB;;;;;;;;;uBAA1BC,mBAAA,CA6BM,OA7BNC,UA6BM,GA3BJC,YAAA,CAoBWC,mBAAA;IApBAC,IAAI,EAAEC,KAAA,CAAAC,SAAS;IAAEC,MAAM,EAAN,EAAM;IAACC,MAAM,EAAN;;sBACjC,MAA0D,CAA1DN,YAAA,CAA0DO,0BAAA;MAAzCC,IAAI,EAAC,MAAM;MAACC,KAAK,EAAC;QACnCT,YAAA,CAIkBO,0BAAA;MAJDE,KAAK,EAAC,MAAM;MAACC,KAAK,EAAC,KAAK;MAACC,KAAK,EAAC;;MACnCC,OAAO,EAAAC,QAAA,CAAEC,KAAK,KACvBd,YAAA,CAAsFe,oBAAA;QAA3EC,IAAI,EAAC,SAAS;QAACC,IAAI,EAAC,OAAO;QAAEC,OAAK,EAAAC,MAAA,IAAEC,QAAA,CAAAC,IAAI,CAACP,KAAK,CAACQ,GAAG,CAACC,OAAO;;0BAAG,MAAEC,MAAA,QAAAA,MAAA,O,iBAAF,IAAE,E;;;;QAG9ExB,YAAA,CAA4DO,0BAAA;MAA3CC,IAAI,EAAC,MAAM;MAACC,KAAK,EAAC;QACnCT,YAAA,CAWkBO,0BAAA;MAXDE,KAAK,EAAC,IAAI;MAACC,KAAK,EAAC,KAAK;MAACC,KAAK,EAAC;;MACjCC,OAAO,EAAAC,QAAA,CAAEC,KAAK,KACvBd,YAAA,CAOgByB,wBAAA;QANdC,KAAK,EAAC,eAAe;QACpBC,SAAO,EAAAR,MAAA,IAAEC,QAAA,CAAAQ,YAAY,CAACd,KAAK,CAACQ,GAAG,CAACO,EAAE;;QAExBC,SAAS,EAAAjB,QAAA,CAClB,MAAsD,CAAtDb,YAAA,CAAsDe,oBAAA;UAA3CC,IAAI,EAA