e\"\r\n            :key=\"row.id\"\r\n            class=\"follow-card\"\r\n          >\r\n            <!-- 卡片顶部装饰 -->\r\n            <div class=\"card-top-bar\"></div>\r\n\r\n            <!-- 头像区 -->\r\n            <div class=\"avatar-section\">\r\n              <div class=\"avatar-ring\">\r\n                <el-avatar :size=\"64\" class=\"follow-avatar\">\r\n                  {{ row.commentUser ? row.commentUser[0].toUpperCase() : 'U' }}\r\n                </el-avatar>\r\n              </div>\r\n              <div class=\"following-tag\">\r\n                <el-icon><Check /></el-icon>\r\n                已关注\r\n              </div>\r\n            </div>\r\n\r\n            <!-- 用户信息 -->\r\n            <div class=\"user-info\">\r\n              <h3 class=\"user-name\">{{ row.commentUser }}</h3>\r\n              <p class=\"user-role\">\r\n                <el-icon><EditPen /></el-icon>\r\n                长评作者\r\n              </p>\r\n            </div>\r\n\r\n            <!-- 分割线 -->\r\n            <div class=\"card-divider\"></div>\r\n\r\n            <!-- 操作按钮 -->\r\n            <div class=\"card-actions\">\r\n              <el-button\r\n                type=\"primary\"\r\n                class=\"view-btn\"\r\n                @click=\"viewWorks(row.commentUser)\"\r\n              >\r\n                <el-icon><Picture /></el-icon>\r\n                查看作品\r\n              </el-button>\r\n              <el-popconfirm\r\n                title=\"确定取消关注吗？\"\r\n                confirm-button-text=\"取消关注\"\r\n                cancel-button-text=\"再想想\"\r\n                @confirm=\"cancel(row)\"\r\n              >\r\n                <template #reference>\r\n                  <el-button class=\"cancel-btn\">\r\n                    <el-icon><Remove /></el-icon>\r\n                    取消关注\r\n                  </el-button>\r\n                </template>\r\n              </el-popconfirm>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n      </div>\r\n    </div>