age-header\">\r\n      <div class=\"header-left\">\r\n        <h2 class=\"page-title\">\r\n          <i class=\"el-icon-star-on title-icon\"></i>\r\n          我收藏的评论\r\n        </h2>\r\n        <span class=\"item-count\">共 {{ tableData.length }} 条</span>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 空状态 -->\r\n    <div v-if=\"tableData.length === 0\" class=\"empty-state\">\r\n      <i class=\"el-icon-star-off empty-icon\"></i>\r\n      <p class=\"empty-text\">暂无收藏内容</p>\r\n      <p class=\"empty-hint\">去浏览信息，收藏感兴趣的评论吧</p>\r\n    </div>\r\n\r\n    <!-- 收藏列表 -->\r\n    <div v-else class=\"collect-list\">\r\n      <div\r\n        v-for=\"item in tableData\"\r\n        :key=\"item.id\"\r\n        class=\"collect-item\"\r\n      >\r\n        <div class=\"item-main\">\r\n          <div class=\"item-top\">\r\n            <div class=\"item-name\">\r\n              <i class=\"el-icon-document item-icon\"></i>\r\n              <span>{{ item.name }}</span>\r\n            </div>\r\n            <span class=\"item-time\">\r\n              <i class=\"el-icon-time\"></i>\r\n              {{ item.time }}\r\n            </span>\r\n          </div>\r\n\r\n          <div class=\"item-actions\">\r\n            <el-button\r\n              type=\"primary\"\r\n              size=\"small\"\r\n              icon=\"el-icon-view\"\r\n              @click=\"show(item.content)\"\r\n              class=\"view-btn\"\r\n            >\r\n              查看评论\r\n            </el-button>\r\n            <el-popconfirm\r\n              title=\"确定要取消收藏这条评论吗？\"\r\n              @confirm=\"handleDelete(item.id)\"\r\n              confirm-button-text=\"确定\"\r\n              cancel-button-text=\"取消\"\r\n            >\r\n              <template #reference>\r\n                <el-button\r\n                  size=\"small\"\r\n                  icon=\"el-icon-delete\"\r\n                  class=\"delete-btn\"\r\n                >\r\n                  取消收藏\r\n                </el-button>\r\n              </template>\r\n            </el-popconfirm>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 查看长评弹框 -->\r\n    <el-dialog\r\n      title=\"收藏的评论\"\r\n      v-model=\"vis\"\r\n      width=\"560px\"\r\n      class=\"collect-dialog\"\r\n    >\r\n      <el-card class=\"preview-card\" shadow=\"never\">\r\n        <v-md-preview :text=\"longComment\"></v-md-preview>\r\n      </el-card>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from \"@/utils/request\";\r\n\r\nexport default {\r\n  name: \"Collect\",\r\n  data() {\r\n    return {\r\n      tableData: [],\r\n      longComment: \"\",\r\n      vis: false,\r\n      user: JSON.parse(sessionStorage.getItem(\"user\") || \"{}\")\r\n    };\r\n  },\r\n  created() {\r\n    this.load();\r\n  },\r\n  methods: {\r\n    load() {\r\n      request.get(`/collect/user/${this.user.id}`).then(res => {\r\n        if (res.code === \"0\") {\r\n          this.tableData = res.data;\r\n        } else {\r\n          this.$message.error(res.msg || \"加载失败\");\r\n        }\r\n      });\r\n    },\r\n    show(content) {\r\n      this.longComment = content;\r\n      this.vis = true;\r\n    },\r\n    handleDelete(id) {\r\n      request.delete(`/collect/${id}`).then(res => {\r\n        if (res.code === \"0\") {\r\n          this.$message.success(\"已取消收藏\");\r\n          this.load();\r\n        } else {\r\n          this.$message.error(res.msg || \"取消失败\");\r\n        }\r\n      }).catch(() => {\r\n        this.$message.error(\"操作失败，请稍后重试\");\r\n      });\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.collect-container {\r\n  padding: var(--spacing-sm) 0;\r\n}\r\n\r\n/* ── 页面标题 ── */\r\n.page-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin-bottom: var(--spacing-xl);\r\n  padding-bottom: var(--spacing-md);\r\n  border-bottom: 2px solid var(--border-lighter);\r\n}\r\n\r\n.header-left {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--spacing-base);\r\n}\r\n\r\n.page-title {\r\n  font-size: var(--font-size-xl);\r\n  font-weight: var(--font-weight-bold);\r\n  color: var(--text-primary);\r\n  margin: 0;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--spacing-sm);\r\n}\r\n\r\n.title-icon {\r\n  color: var(--warning-color);\r\n  font-size: var(--font-size-xl);\r\n}\r\n\r\n.item-count {\r\n  font-size: var(--font-size-sm);\r\n  color: var(--text-tertiary);\r\n  background: var(--bg-tertiary);\r\n  padding: 3px 10px;\r\n  border-radius: var(--radius-full);\r\n}\r\n\r\n/* ── 空状态 ── */\r\n.empty-state {\r\n  text-align: center;\r\n  padding: var(--spacing-4xl) var(--spacing-lg);\r\n}\r\n\r\n.empty-icon {\r\n  font-size: 56px;\r\n  color: var(--text-disabled);\r\n  display: block;\r\n  margin-bottom: var(--spacing-md);\r\n}\r\n\r\n.empty-text {\r\n  font-size: var(--font-size-lg);\r\n  color: var(--text-tertiary);\r\n  margin: 0 0 var(--spacing-sm);\r\n  font-weight: var(--font-weight-medium);\r\n}\r\n\r\n.empty-hint {\r\n  font-size: var(--font-size-sm);\r\n  color: var(--text-disabled);\r\n  margin: 0;\r\n}\r\n\r\n/* ── 收藏列表 ── */\r\n.collect-list {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--spacing-base);\r\n}\r\n\r\n.collect-item {\r\n  background: var(--bg-secondary);\r\n  border: 1px solid var(--border-lighter);\r\n  border-radius: var(--radius-md);\r\n  padding: var(--spacing-md) var(--spacing-lg);\r\n  transition: all var(--transition-base);\r\n}\r\n\r\n.collect-item:hover {\r\n  background: var(--bg-hover);\r\n  border-color: var(--border-primary);\r\n  box-shadow: var(--shadow-sm);\r\n  transform: translateX(3px);\r\n}\r\n\r\n.item-main {}\r\n\r\n.item-top {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin-bottom: var(--spacing-base);\r\n  flex-wrap: wrap;\r\n  gap: var(--spacing-sm);\r\n}\r\n\r\n.item-name {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--spacing-sm);\r\n  font-size: var(--font-size-md);\r\n  font-weight: var(--font-weight-semibold);\r\n  color: var(--text-primary);\r\n  flex: 1;\r\n  min-width: 0;\r\n}\r\n\r\n.item-name span {\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n  white-space: nowrap;\r\n}\r\n\r\n.item-icon {\r\n  color: var(--primary-color);\r\n  font-size: 15px;\r\n  flex-shrink: 0;\r\n}\r\n\r\n.item-time {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 4px;\r\n  font-size: var(--font-size-xs);\r\n  color: var(--text-disabled);\r\n  flex-shrink: 0;\r\n}\r\n\r\n.item-time i {\r\n  font-size: 12px;\r\n}\r\n\r\n.item-actions {\r\n  display: flex;\r\n  gap: var(--spacing-sm);\r\n  justify-content: flex-end;\r\n}\r\n\r\n.view-btn {\r\n  border-radius: var(--radius-sm) !important;\r\n}\r\n\r\n.delete-btn {\r\n  border-radius: var(--radius-sm) !important;\r\n  color: var(--danger-color) !important;\r\n  border-color: var(--danger-color) !important;\r\n  background: transparent !important;\r\n}\r\n\r\n.delete-btn:hover {\r\n  background: var(--danger-light) !important;\r\n}\r\n\r\n/* ── 弹框预览 ── */\r\n.collect-dialog :deep(.el-dialog__header) {\r\n  background: linear-gradient(135deg, var(--bg-tertiary), var(--bg-secondary));\r\n  border-bottom: 1px solid var(--border-lighter);\r\n}\r\n\r\n.preview-card {\r\n  border: none !important;\r\n  box-shadow: none !important;\r\n  background: transparent !important;\r\n  transform: none !important;\r\n}\r\n\r\n.preview-card :deep(.el-card__body) {\r\n  padding: 0;\r\n}\r\n</style>\r\n"]}]}