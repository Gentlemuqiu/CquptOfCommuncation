g);\r\n  }\r\n\r\n  .form-row {\r\n    grid-template-columns: 1fr;\r\n  }\r\n\r\n  .form-footer {\r\n    flex-direction: column;\r\n    align-items: flex-start;\r\n  }\r\n\r\n  .form-actions {\r\n    width: 100%;\r\n    justify-content: flex-end;\r\n  }\r\n}\r\n</style>\r\n"]}]}