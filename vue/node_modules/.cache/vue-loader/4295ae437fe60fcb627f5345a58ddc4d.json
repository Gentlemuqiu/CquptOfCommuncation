ueProjects/CquptOfCommuncation/vue/src/views/Login.vue","sourceRoot":"","sourcesContent":["<template>\r\n  <div class=\"login-page\">\r\n    <div class=\"login-wrapper\">\r\n      <div class=\"login-card\">\r\n        <div class=\"login-header\">\r\n          <div class=\"logo-container\">\r\n            <img src=\"../assets/image/cqupt.svg\" alt=\"Logo\" class=\"login-logo\">\r\n          </div>\r\n          <h1 class=\"login-title\">欢迎登录</h1>\r\n          <p class=\"login-subtitle\">就业信息中心</p>\r\n        </div>\r\n        \r\n        <el-form \r\n          ref=\"form\" \r\n          :model=\"form\" \r\n          size=\"large\" \r\n          :rules=\"rules\"\r\n          class=\"login-form\"\r\n        >\r\n          <el-form-item prop=\"username\">\r\n            <el-input \r\n              prefix-icon=\"el-icon-user-solid\" \r\n              v-model=\"form.username\" \r\n              placeholder=\"请输入用户名\"\r\n              class=\"form-input\"\r\n            />\r\n          </el-form-item>\r\n          \r\n          <el-form-item prop=\"password\">\r\n            <el-input \r\n              prefix-icon=\"el-icon-lock\" \r\n              v-model=\"form.password\" \r\n              placeholder=\"请输入密码\" \r\n              show-password\r\n              class=\"form-input\"\r\n              @keyup.enter=\"login\"\r\n            />\r\n          </el-form-item>\r\n          \r\n          <el-form-item class=\"role-group\">\r\n            <el-radio-group v-model=\"form.role\" class=\"role-radio\">\r\n              <el-radio :value=\"1\" border>管理员</el-radio>\r\n              <el-radio :value=\"2\" border>普通用户</el-radio>\r\n            </el-radio-group>\r\n          </el-form-item>\r\n          \r\n          <el-form-item>\r\n            <el-button \r\n              :loading=\"loading\" \r\n              class=\"login-button\" \r\n              type=\"primary\" \r\n              @click=\"login\"\r\n              size=\"large\"\r\n            >\r\n              {{ loading ? '登录中...' : '登 录' }}\r\n            </el-button>\r\n          </el-form-item>\r\n          \r\n          <div class=\"login-footer\">\r\n            <el-link type=\"primary\" @click=\"$router.push('/pass')\" :underline=\"false\">\r\n              忘记密码？\r\n            </el-link>\r\n            <el-link type=\"primary\" @click=\"$router.push('/register')\" :underline=\"false\">\r\n              立即注册 &gt;&gt;\r\n            </el-link>\r\n          </div>\r\n        </el-form>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport request from \"@/utils/request\";\r\n\r\nexport default {\r\n  name: \"Login\",\r\n  data() {\r\n    return {\r\n      form: { username: \"\", password: \"\", role: 1 }, // 初始化登录表单\r\n      loading: false, // 登录按钮加载状态\r\n      rules: {\r\n        username: [{ required: true, message: \"请输入用户名\", trigger: \"blur\" }],\r\n        password: [{ required: true, message: \"请输入密码\", trigger: \"blur\" }],\r\n      },\r\n    };\r\n  },\r\n  created() {\r\n    sessionStorage.removeItem(\"user\"); // 清除缓存用户信息\r\n  },\r\n  methods: {\r\n    async login() {\r\n      // 表单校验\r\n      this.$refs.form.validate(async (valid) => {\r\n        if (valid) {\r\n          this.loading = true; // 开启加载状态\r\n          try {\r\n            const res = await request.post(\"/user/login\", this.form);\r\n            if (res.code === \"0\") {\r\n              this.$message.success(\"登录成功\");\r\n              sessionStorage.setItem(\"user\", JSON.stringify(res.data)); // 缓存用户信息\r\n              const redirectPath = res.data.role !== 1 ? \"/front/home\" : \"/\";\r\n              this.$router.push(redirectPath);\r\n            } else {\r\n              this.$message.error(res.msg);\r\n            }\r\n          } catch (error) {\r\n            this.$message.error(\"网络错误，请稍后再试\");\r\n          } finally {\r\n            this.loading = false; // 关闭加载状态\r\n          }\r\n        }\r\n      });\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.login-page {\r\n  min-height: 100vh;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 50%, #667eea 100%);\r\n  position: relative;\r\n  overflow: hidden;\r\n}\r\n\r\n.login-page::before {\r\n  content: '';\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  right: 0;\r\n  bottom: 0;\r\n  background: url(\"../assets/image/bg.png\") no-repeat center center;\r\n  background-size: cover;\r\n  opacity: 0.08;\r\n  z-index: 0;\r\n}\r\n\r\n.login-page::after {\r\n  content: '';\r\n  position: absolute;\r\n  top: -50%;\r\n  right: -50%;\r\n  width: 200%;\r\n  height: 200%;\r\n  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);\r\n  animation: pulse 15s ease-in-out infinite;\r\n  z-index: 0;\r\n}\r\n\r\n@keyframes pulse {\r\n  0%, 100% {\r\n    transform: scale(1);\r\n    opacity: 0.5;\r\n  }\r\n  50% {\r\n    transform: scale(1.1);\r\n    opacity: 0.8;\r\n  }\r\n}\r\n\r\n.login-wrapper {\r\n  position: relative;\r\n  z-index: 1;\r\n  width: 100%;\r\n  max-width: 450px;\r\n  padding: 20px;\r\n}\r\n\r\n.login-card {\r\n  background: rgba(255, 255, 255, 0.98);\r\n  backdrop-filter: blur(20px);\r\n  border-radius: var(--radius-xl);\r\n  padding: var(--spacing-3xl) var(--spacing-2xl);\r\n  box-shadow: var(--shadow-xl);\r\n  transition: transform var(--transition-base), box-shadow var(--transition-base);\r\n  border: 1px solid rgba(255, 255, 255, 0.3);\r\n}\r\n\r\n.login-card:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 25px 70px rgba(0, 0, 0, 0.35);\r\n}\r\n\r\n.login-header {\r\n  text-align: center;\r\n  margin-bottom: 40px;\r\n}\r\n\r\n.logo-container {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.login-logo {\r\n  width: 60px;\r\n  height: 60px;\r\n  object-fit: contain;\r\n}\r\n\r\n.login-title {\r\n  font-size: var(--font-size-3xl);\r\n  font-weight: var(--font-weight-bold);\r\n  color: var(--text-primary);\r\n  margin: 0 0 var(--spacing-sm) 0;\r\n  background: var(--primary-gradient);\r\n  -webkit-background-clip: text;\r\n  -webkit-text-fill-color: transparent;\r\n  background-clip: text;\r\n}\r\n\r\n.login-subtitle {\r\n  font-size: var(--font-size-md);\r\n  color: var(--text-tertiary);\r\n  margin: 0;\r\n  font-weight: var(--font-weight-medium);\r\n}\r\n\r\n.login-form {\r\n  margin-top: 30px;\r\n}\r\n\r\n.form-input :deep(.el-input__inner) {\r\n  height: 50px;\r\n  border-radius: var(--radius-base);\r\n  border: 1px solid var(--border-base);\r\n  transition: all var(--transition-base);\r\n  font-size: var(--font-size-base);\r\n}\r\n\r\n.form-input :deep(.el-input__inner):focus {\r\n  border-color: var(--primary-color);\r\n  box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.1);\r\n}\r\n\r\n.role-group {\r\n  margin-bottom: 10px;\r\n}\r\n\r\n.role-radio {\r\n  width: 100%;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  gap: 10px;\r\n}\r\n\r\n.role-radio :deep(.el-radio) {\r\n  flex: 1;\r\n  margin: 0;\r\n}\r\n\r\n.role-radio :deep(.el-radio__input.is-checked .el-radio__inner) {\r\n  background-color: var(--primary-color);\r\n  border-color: var(--primary-color);\r\n}\r\n\r\n.role-radio :deep(.el-radio__input.is-checked + .el-radio__label) {\r\n  color: var(--primary-color);\r\n}\r\n\r\n.login-button {\r\n  width: 100%;\r\n  height: 50px;\r\n  font-size: var(--font-size-md);\r\n  font-weight: var(--font-weight-semibold);\r\n  border-radius: var(--radius-base);\r\n  background: var(--primary-gradient);\r\n  border: none;\r\n  transition: all var(--transition-cubic);\r\n}\r\n\r\n.login-button:hover {\r\n  transform: translateY(-2px);\r\n  box-shadow: var(--shadow-primary);\r\n}\r\n\r\n.login-button:active {\r\n  transform: translateY(0);\r\n}\r\n\r\n.login-footer {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-top: 20px;\r\n  padding-top: 20px;\r\n  border-top: 1px solid #e4e7ed;\r\n}\r\n\r\n.login-footer .el-link {\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n}\r\n\r\n</style>\r\n"]}]}