:"","sourcesContent":["<template>\r\n  <aside class=\"admin-aside\">\r\n    <div class=\"aside-title\">\r\n      <i class=\"el-icon-s-grid\"></i>\r\n      <span>管理导航</span>\r\n    </div>\r\n\r\n    <el-menu :default-active=\"path\" router class=\"aside-menu\">\r\n      <el-submenu index=\"system\" v-if=\"systemItems.length\">\r\n        <template #title>\r\n          <span>系统管理</span>\r\n        </template>\r\n        <el-menu-item v-for=\"item in systemItems\" :key=\"item.path\" :index=\"item.path\">\r\n          <i :class=\"item.icon\"></i>\r\n          <span>{{ item.label }}</span>\r\n        </el-menu-item>\r\n      </el-submenu>\r\n\r\n      <el-menu-item v-for=\"item in normalItems\" :key=\"item.path\" :index=\"item.path\">\r\n        <i :class=\"item.icon\"></i>\r\n        <span>{{ item.label }}</span>\r\n      </el-menu-item>\r\n    </el-menu>\r\n  </aside>\r\n</template>\r\n\r\n<script>\r\nimport request from \"@/utils/request\";\r\nimport { ADMIN_SIDEBAR_ITEMS } from \"@/config/navigation\";\r\n\r\nexport default {\r\n  name: \"Aside\",\r\n  data() {\r\n    return {\r\n      user: {},\r\n      path: this.$route.path   // 设置默认高亮的菜单\r\n    }\r\n  },\r\n  computed: {\r\n    filteredItems() {\r\n      return ADMIN_SIDEBAR_ITEMS.filter(item => {\r\n        if (!item.requireRole) return true;\r\n        return item.requireRole === this.user.role;\r\n      });\r\n    },\r\n    systemItems() {\r\n      return this.filteredItems.filter(item => item.group === '系统管理');\r\n    },\r\n    normalItems() {\r\n      return this.filteredItems.filter(item => item.group !== '系统管理');\r\n    }\r\n  },\r\n  created() {\r\n    let userStr = sessionStorage.getItem(\"user\") || \"{}\"\r\n    this.user = JSON.parse(userStr)\r\n\r\n    // 请求服务端，确认当前登录用户的 合法信息\r\n    if (this.user.id) {\r\n      request.get(\"/user/\" + this.user.id).then(res => {\r\n        if (res.code === '0') {\r\n          this.user = res.data\r\n        }\r\n      })\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.admin-aside {\r\n  width: 220px;\r\n  flex-shrink: 0;\r\n  background: var(--bg-primary);\r\n  border: 1px solid var(--border-light);\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: var(--shadow-base);\r\n  overflow: hidden;\r\n}\r\n\r\n.aside-title {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--spacing-sm);\r\n  padding: var(--spacing-md) var(--spacing-lg);\r\n  color: var(--text-primary);\r\n  font-weight: var(--font-weight-semibold);\r\n  border-bottom: 1px solid var(--border-light);\r\n  background: linear-gradient(135deg, #ecfeff 0%, #f8fafc 100%);\r\n}\r\n\r\n.aside-menu {\r\n  border-right: none;\r\n}\r\n\r\n.aside-menu :deep(.el-menu-item),\r\n.aside-menu :deep(.el-submenu__title) {\r\n  height: 44px;\r\n  line-height: 44px;\r\n}\r\n\r\n.aside-menu :deep(.el-menu-item i),\r\n.aside-menu :deep(.el-submenu__title i) {\r\n  margin-right: var(--spacing-sm);\r\n}\r\n\r\n.aside-menu :deep(.el-menu-item.is-active) {\r\n  background: #ecfeff;\r\n  color: var(--primary-color);\r\n  border-right: 2px solid var(--primary-color);\r\n}\r\n\r\n@media (max-width: 900px) {\r\n  .admin-aside {\r\n    width: 100%;\r\n  }\r\n}\r\n</style>\r\n"]}]}